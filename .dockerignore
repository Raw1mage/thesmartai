# =============================================================================
# Docker Ignore File
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# IDE
.idea
.vscode
*.swp
*.swo
*~

# Build outputs
dist/
*.tar.gz
*.zip

# Node modules (will be installed in container)
node_modules/

# Test files
*.test.ts
*.spec.ts
__tests__/
coverage/
.nyc_output/

# Documentation
*.md
!README.md
docs/

# Local development
.env
.env.*
!.env.example
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp

# Cache
.cache/
.turbo/
.parcel-cache/

# SST / Infrastructure
.sst/
sst.config.ts

# Editor config
.editorconfig
.prettierrc*
.eslintrc*
biome.json
turbo.json
