# =============================================================================
# Opencode Docker Environment Configuration
# =============================================================================
# Copy this file to .env and modify as needed:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Web Server Settings
# -----------------------------------------------------------------------------

# Web service port (default: 1080)
OPENCODE_PORT=1080

# Web UI authentication (REQUIRED for production)
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=

# -----------------------------------------------------------------------------
# Directory Paths
# -----------------------------------------------------------------------------

# Unified data directory (all config/cache/state stored here)
OPENCODE_ROOT=/opt/opencode

# Workspace directory - mount your code repository here
WORKSPACE=./workspace

# Projects directory - mount your projects for online processing
# PROJECTS_DIR=$HOME/projects

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------

TZ=Asia/Taipei

# -----------------------------------------------------------------------------
# API Keys (Optional - can also use auth.json)
# -----------------------------------------------------------------------------

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (GPT)
# OPENAI_API_KEY=sk-xxx

# Google (Gemini)
# GOOGLE_API_KEY=AIzaSyxxx

# OpenCode Zen
# OPENCODE_API_KEY=xxx

# -----------------------------------------------------------------------------
# Advanced Settings
# -----------------------------------------------------------------------------

# Debug mode
# OPENCODE_DEBUG=1

# Log level (DEBUG, INFO, WARN, ERROR)
# OPENCODE_LOG_LEVEL=INFO

# Disable specific providers (comma-separated)
# OPENCODE_DISABLED_PROVIDERS=openrouter,vercel

# Custom models.dev API endpoint
# MODELS_DEV_API_JSON=/path/to/api.json
