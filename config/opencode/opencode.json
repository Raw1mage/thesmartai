{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-antigravity-auth@latest"
  ],
  "permissionMode": "auto",
  "disabled_providers": [
    "github-copilot",
    "deepseek"
  ],
  "enabled_providers": [
    "opencode",
    "google",
    "openai",
    "anthropic"
  ],
  "keybinds": {
    "command_list": "<leader>p"
  },
  "command": {
    "status": {
      "description": "Show token usage and rate limit resets",
      "template": "Please run the bash command `opencode-status {{message}}` and report the result."
    },
    "openai-switch": {
      "description": "Switch active OpenAI account (e.g. /openai-switch 2)",
      "template": "Please run the bash command `opencode-openai-switch {{message}}` and confirm to the user."
    },
  },
  "provider": {
    "opencode": {
      "models": {
        "big-pickle": {
          "name": "Big Pickle (Built-in)"
        },
        "gpt-5-nano": {
          "name": "GPT-5 Nano (Built-in)"
        }
      }
    },
    "anthropic": {
      "models": {
        "claude-3-5-haiku-20241022": {
          "name": "Claude 3.5 Haiku (2024-10-22)"
        },
        "claude-opus-4-5": {
          "name": "Claude Opus 4.5"
        },
        "claude-opus-4-5-20251101": {
          "name": "Claude Opus 4.5 (2025-11-01)"
        },
        "claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5"
        },
        "claude-sonnet-4-5-20250929": {
          "name": "Claude Sonnet 4.5 (2025-09-29)"
        }
      }
    },
    "google": {
      "models": {
        "gemini-1.5-flash": {
          "name": "Gemini 1.5 Flash",
          "limit": {
            "context": 1048576,
            "output": 8192
          }
        },
        "gemini-1.5-pro": {
          "name": "Gemini 1.5 Pro",
          "limit": {
            "context": 2097152,
            "output": 8192
          }
        },
        "gemini-2.0-flash-exp": {
          "name": "Gemini 2.0 Flash (Experimental)",
          "limit": {
            "context": 1048576,
            "output": 8192
          }
        },
        "gemini-2.0-flash-thinking-exp": {
          "name": "Gemini 2.0 Flash Thinking (Experimental)",
          "limit": {
            "context": 32767,
            "output": 8192
          }
        }
      }
    },
    "openai": {
      "models": {
        "gpt-5.1-codex": {
          "name": "GPT-5.1 Codex (Plus Subscription)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "gpt-5.1-codex-max": {
          "name": "GPT-5.1 Codex Max (Plus Subscription)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "gpt-5.1-codex-mini": {
          "name": "GPT-5.1 Codex Mini (Plus Subscription)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "gpt-5.2": {
          "name": "GPT-5.2 (Plus Subscription)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "gpt-5.2-codex": {
          "name": "GPT-5.2 Codex (Plus Subscription)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        }
      }
    }
  }
}