{
  "$schema": "https://json.schemastore.org/package.json",
  "version": "1.1.51",
  "name": "opencode",
  "description": "AI-powered development tool",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "bun run sync:back && bash script/dev-sync-config.sh && bun run script/runtime-init-check.ts && bun --conditions=browser ./packages/opencode/src/index.ts",
    "dev:web": "bun run sync:back && bash script/dev-sync-config.sh && bun run script/runtime-init-check.ts && OPENCODE_NO_GATEWAY=1 ./webctl.sh dev-start",
    "dev:gateway": "bun run sync:back && bash script/dev-sync-config.sh && bun run script/runtime-init-check.ts && ./webctl.sh dev-start",
    "dev:debug": "OPENCODE_DEBUG_LOG=1 bun run sync:back && bash script/dev-sync-config.sh && bun run script/runtime-init-check.ts && OPENCODE_DEBUG_LOG=1 bun --conditions=browser ./packages/opencode/src/index.ts",
    "dev:full": "bun run sync:back && bash script/dev-sync-config.sh && bun run script/runtime-init-check.ts && bun --conditions=browser ./packages/opencode/src/index.ts",
    "dev:perfprobe": "bun run sync:back && bash script/dev-sync-config.sh && bun run script/runtime-init-check.ts && OPENCODE_TUI_PERF_PROBE=1 OPENCODE_TUI_DISABLE_FOOTER_META=1 OPENCODE_TUI_DISABLE_MONITOR_POLL=1 bun --conditions=browser ./packages/opencode/src/index.ts",
    "check": "bun run lint && bun run verify:typecheck",
    "lint": "eslint .",
    "typecheck": "bun turbo typecheck",
    "verify:typecheck": "bun scripts/typecheck-with-baseline.ts",
    "test": "bun scripts/test-with-baseline.ts",
    "build": "bun run script/build.ts",
    "build:help": "bun run script/build.ts --help",
    "build:with-models": "bun run script/build.ts --refresh-models",
    "models:update-snapshot": "bun run script/update-models-snapshot.ts",
    "models:update-snapshot:help": "bun run script/update-models-snapshot.ts --help",
    "install": "bun run script/install.ts",
    "prepare": "husky && if [ -f .husky/pre-push ]; then chmod +x .husky/pre-push; fi && if [ -d .husky/_ ]; then chmod +x .husky/_/* 2>/dev/null || true; fi",
    "sync:back": "bash script/sync-config-back.sh"
  },
  "bin": {
    "opencode": "./bin/opencode"
  },
  "exports": {
    "./*": "./packages/opencode/src/*.ts"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "packages/mcp/*",
      "packages/console/*",
      "packages/sdk/js",
      "packages/slack"
    ],
    "catalog": {
      "@types/bun": "1.3.9",
      "@octokit/rest": "22.0.0",
      "@hono/zod-validator": "0.4.2",
      "ulid": "3.0.1",
      "@kobalte/core": "0.13.11",
      "@types/luxon": "3.7.1",
      "@types/node": "22.13.9",
      "@types/semver": "7.7.1",
      "@tsconfig/node22": "22.0.2",
      "@tsconfig/bun": "1.0.9",
      "@cloudflare/workers-types": "4.20251008.0",
      "@openauthjs/openauth": "0.0.0-20250322224806",
      "@pierre/diffs": "1.1.0-beta.13",
      "@solid-primitives/storage": "4.3.3",
      "@tailwindcss/vite": "4.1.11",
      "diff": "8.0.2",
      "dompurify": "3.3.1",
      "ai": "5.0.119",
      "hono": "4.10.7",
      "hono-openapi": "1.1.2",
      "fuzzysort": "3.1.0",
      "luxon": "3.6.1",
      "marked": "17.0.1",
      "marked-shiki": "1.2.1",
      "@playwright/test": "1.51.0",
      "typescript": "5.8.2",
      "@typescript/native-preview": "7.0.0-dev.20251207.1",
      "zod": "4.1.8",
      "remeda": "2.26.0",
      "shiki": "3.20.0",
      "solid-list": "0.3.0",
      "tailwindcss": "4.1.11",
      "virtua": "0.42.3",
      "vite": "7.1.4",
      "@solidjs/meta": "0.29.4",
      "@solidjs/router": "0.15.4",
      "@solidjs/start": "https://pkg.pr.new/@solidjs/start@dfb2020",
      "solid-js": "1.9.10",
      "vite-plugin-solid": "2.11.10"
    }
