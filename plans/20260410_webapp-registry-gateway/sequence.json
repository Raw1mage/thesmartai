[
  {
    "diagram_title": "Anonymous User Accesses Public Webapp",
    "scenario": "Unauthenticated browser request hits a registered public route and is proxied to the webapp backend",
    "participants": [
      { "id": "P1", "name": "Browser", "type": "actor" },
      { "id": "P2", "name": "HTTP Accumulator", "type": "component", "componentRef": "C1" },
      { "id": "P3", "name": "Web Route Matcher", "type": "component", "componentRef": "C2" },
      { "id": "P4", "name": "Splice Proxy", "type": "component", "componentRef": "C5" },
      { "id": "P5", "name": "Webapp Frontend", "type": "system", "componentRef": "CT4" }
    ],
    "messages": [
      { "id": "MSG1", "from": "P1", "to": "P2", "label": "GET /cecelearn/index.html HTTP/1.1", "type": "sync", "order": 1 },
      { "id": "MSG2", "from": "P2", "to": "P3", "label": "match_web_route(\"/cecelearn/index.html\")", "type": "sync", "order": 2 },
      { "id": "MSG3", "from": "P3", "to": "P2", "label": "WebRoute{prefix=/cecelearn, host=127.0.0.1, port=5173}", "type": "return", "order": 3 },
      { "id": "MSG4", "from": "P2", "to": "P4", "label": "connect(127.0.0.1:5173) + alloc_conn + pipe2", "type": "sync", "order": 4 },
      { "id": "MSG5", "from": "P4", "to": "P5", "label": "write(raw_http_request)", "type": "async", "order": 5 },
      { "id": "MSG6", "from": "P5", "to": "P4", "label": "HTTP/1.1 200 OK + HTML body", "type": "async", "order": 6 },
      { "id": "MSG7", "from": "P4", "to": "P1", "label": "splice(webapp_response → client)", "type": "async", "order": 7 }
    ],
    "fragments": []
  },
  {
    "diagram_title": "No Route Match Falls Through to Auth",
    "scenario": "Request path does not match any public route, proceeds to JWT validation",
    "participants": [
      { "id": "P1", "name": "Browser", "type": "actor" },
      { "id": "P2", "name": "HTTP Accumulator", "type": "component", "componentRef": "C1" },
      { "id": "P3", "name": "Web Route Matcher", "type": "component", "componentRef": "C2" },
      { "id": "P4", "name": "JWT Validator", "type": "component", "componentRef": "C4" }
    ],
    "messages": [
      { "id": "MSG1", "from": "P1", "to": "P2", "label": "GET / HTTP/1.1 (no oc_jwt cookie)", "type": "sync", "order": 1 },
      { "id": "MSG2", "from": "P2", "to": "P3", "label": "match_web_route(\"/\")", "type": "sync", "order": 2 },
      { "id": "MSG3", "from": "P3", "to": "P2", "label": "NULL (no match)", "type": "return", "order": 3 },
      { "id": "MSG4", "from": "P2", "to": "P4", "label": "check JWT cookie", "type": "sync", "order": 4 },
      { "id": "MSG5", "from": "P4", "to": "P1", "label": "HTTP 200 Login Page HTML", "type": "return", "order": 5 }
    ],
    "fragments": []
  },
  {
    "diagram_title": "SIGHUP Route Reload",
    "scenario": "Admin modifies routes.conf and sends SIGHUP to reload without restart",
    "participants": [
      { "id": "P1", "name": "Admin", "type": "actor" },
      { "id": "P2", "name": "webctl reload-routes", "type": "component", "componentRef": "C8" },
      { "id": "P3", "name": "SIGHUP Handler", "type": "component", "componentRef": "C6" },
      { "id": "P4", "name": "Route Table Loader", "type": "component", "componentRef": "C3" }
    ],
    "messages": [
      { "id": "MSG1", "from": "P1", "to": "P2", "label": "webctl.sh reload-routes", "type": "sync", "order": 1 },
      { "id": "MSG2", "from": "P2", "to": "P3", "label": "kill -HUP <gateway_pid>", "type": "async", "order": 2 },
      { "id": "MSG3", "from": "P3", "to": "P3", "label": "g_reload_routes = 1", "type": "sync", "order": 3 },
      { "id": "MSG4", "from": "P3", "to": "P4", "label": "load_web_routes() (next epoll iteration)", "type": "sync", "order": 4 },
      { "id": "MSG5", "from": "P4", "to": "P4", "label": "fopen + sscanf + sort by prefix length", "type": "sync", "order": 5 }
    ],
    "fragments": []
  },
  {
    "diagram_title": "Backend Connection Failure — Silent Redirect",
    "scenario": "Public route matches but backend port is not listening; Gateway redirects to homepage",
    "participants": [
      { "id": "P1", "name": "Browser", "type": "actor" },
      { "id": "P2", "name": "HTTP Accumulator", "type": "component", "componentRef": "C1" },
      { "id": "P3", "name": "Web Route Matcher", "type": "component", "componentRef": "C2" },
      { "id": "P4", "name": "Error Redirector", "type": "component", "componentRef": "C11" }
    ],
    "messages": [
      { "id": "MSG1", "from": "P1", "to": "P2", "label": "GET /cecelearn HTTP/1.1", "type": "sync", "order": 1 },
      { "id": "MSG2", "from": "P2", "to": "P3", "label": "match_web_route(\"/cecelearn\")", "type": "sync", "order": 2 },
      { "id": "MSG3", "from": "P3", "to": "P2", "label": "WebRoute{port=5173}", "type": "return", "order": 3 },
      { "id": "MSG4", "from": "P2", "to": "P4", "label": "connect(127.0.0.1:5173) → ECONNREFUSED", "type": "sync", "order": 4 },
      { "id": "MSG5", "from": "P4", "to": "P1", "label": "HTTP 302 Found Location: /", "type": "return", "order": 5 }
    ],
    "fragments": []
  },
  {
    "diagram_title": "Route Registration via Control Socket",
    "scenario": "Daemon registers a public webapp route through ctl.sock IPC",
    "participants": [
      { "id": "P1", "name": "User (via AI Skill)", "type": "actor" },
      { "id": "P2", "name": "Per-User Daemon", "type": "system", "componentRef": "CT2" },
      { "id": "P3", "name": "Control Socket Server", "type": "component", "componentRef": "C9" },
      { "id": "P4", "name": "Web Route Matcher", "type": "component", "componentRef": "C2" },
      { "id": "P5", "name": "Route Persistence", "type": "component", "componentRef": "C10" }
    ],
    "messages": [
      { "id": "MSG1", "from": "P1", "to": "P2", "label": "skill: publish /cecelearn to port 5173", "type": "sync", "order": 1 },
      { "id": "MSG2", "from": "P2", "to": "P3", "label": "connect(ctl.sock) + {action:publish, prefix:/cecelearn, ...}", "type": "sync", "order": 2 },
      { "id": "MSG3", "from": "P3", "to": "P4", "label": "check prefix duplicate", "type": "sync", "order": 3 },
      { "id": "MSG4", "from": "P4", "to": "P3", "label": "no conflict", "type": "return", "order": 4 },
      { "id": "MSG5", "from": "P3", "to": "P3", "label": "SO_PEERCRED → get peer uid", "type": "sync", "order": 5 },
      { "id": "MSG6", "from": "P3", "to": "P4", "label": "insert route into g_web_routes[]", "type": "sync", "order": 6 },
      { "id": "MSG7", "from": "P3", "to": "P5", "label": "flush_web_routes() → write routes.conf", "type": "async", "order": 7 },
      { "id": "MSG8", "from": "P3", "to": "P2", "label": "{ok:true}", "type": "return", "order": 8 }
    ],
    "fragments": [
      { "id": "FRAG1", "type": "alt", "label": "Prefix already exists", "messageRefs": ["MSG3", "MSG4"] }
    ]
  }
