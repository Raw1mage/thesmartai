{
  "model": "GRAFCET",
  "title": "AgentMemory Analysis Flow",
  "steps": [
    { "id": "S1", "name": "Plan initialized", "initial": true },
    { "id": "S2", "name": "Architecture context read" },
    { "id": "S3", "name": "Submodule imported" },
    { "id": "S4", "name": "AgentMemory analyzed" },
    { "id": "S5", "name": "Recommendations recorded" }
  ],
  "transitions": [
    { "from": "S1", "to": "S2", "condition": "plan and event skeleton exist" },
    { "from": "S2", "to": "S3", "condition": "no conflicting refs/agentmemory path" },
    { "from": "S3", "to": "S4", "condition": "submodule clone succeeds" },
    { "from": "S4", "to": "S5", "condition": "capabilities and risks identified" }
  ]
}
