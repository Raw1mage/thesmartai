{
  "version": "drawmiat-grafcet-v1",
  "title": "Session Focus / Scroll Guard State Machine",
  "steps": [
    { "id": "S0", "name": "Follow bottom", "initial": true },
    { "id": "S1", "name": "Free reading" },
    { "id": "S2", "name": "Explicit navigation" }
  ],
  "transitions": [
    { "id": "T1", "from": "S0", "to": "S1", "condition": "user scrolls away from bottom" },
    { "id": "T2", "from": "S1", "to": "S0", "condition": "user clicks resume or returns to bottom" },
    { "id": "T3", "from": "S1", "to": "S2", "condition": "user activates message hash/navigation" },
    { "id": "T4", "from": "S2", "to": "S1", "condition": "navigation completes without resume-bottom" }
  ]
}
