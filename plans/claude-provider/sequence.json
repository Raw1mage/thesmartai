[
  {
    "diagram_title": "OAuth Code Paste Login Flow",
    "scenario": "User authenticates via browser OAuth PKCE with code paste callback",
    "participants": [
      { "id": "P1", "name": "Host (TypeScript)", "type": "actor", "componentRef": "C9" },
      { "id": "P2", "name": "FFI Binding", "type": "component", "componentRef": "C8" },
      { "id": "P3", "name": "Auth Manager", "type": "component", "componentRef": "C2" },
