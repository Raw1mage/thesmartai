      { "id": "P6", "name": "User Browser", "type": "actor", "componentRef": "SYS2" }
    ],
    "messages": [
      { "id": "MSG1", "from": "P1", "to": "P2", "label": "loginStart()", "type": "sync", "order": 1 },
      { "id": "MSG2", "from": "P2", "to": "P3", "label": "claude_login_start()", "type": "sync", "order": 2 },
      { "id": "MSG3", "from": "P3", "to": "P3", "label": "generate PKCE verifier + challenge", "type": "sync", "order": 3 },
      { "id": "MSG4", "from": "P3", "to": "P2", "label": "return { url, verifier }", "type": "return", "order": 4 },
      { "id": "MSG5", "from": "P2", "to": "P1", "label": "return { url, verifier }", "type": "return", "order": 5 },
      { "id": "MSG6", "from": "P1", "to": "P6", "label": "open(url)", "type": "async", "order": 6 },
      { "id": "MSG7", "from": "P6", "to": "P5", "label": "GET /oauth/authorize", "type": "sync", "order": 7 },
      { "id": "MSG8", "from": "P5", "to": "P6", "label": "redirect to callback page with code", "type": "return", "order": 8 },
      { "id": "MSG9", "from": "P6", "to": "P1", "label": "user pastes authorization code", "type": "sync", "order": 9 },
      { "id": "MSG10", "from": "P1", "to": "P2", "label": "loginExchange(code, verifier)", "type": "sync", "order": 10 },
      { "id": "MSG11", "from": "P2", "to": "P3", "label": "claude_login_exchange(code, verifier)", "type": "sync", "order": 11 },
      { "id": "MSG12", "from": "P3", "to": "P5", "label": "POST /v1/oauth/token (code + verifier)", "type": "sync", "order": 12 },
      { "id": "MSG13", "from": "P5", "to": "P3", "label": "{ access_token, refresh_token, expires_in }", "type": "return", "order": 13 },
      { "id": "MSG14", "from": "P3", "to": "P5", "label": "GET /api/oauth/profile", "type": "sync", "order": 14 },
      { "id": "MSG15", "from": "P5", "to": "P3", "label": "{ email, organizationUuid }", "type": "return", "order": 15 },
      { "id": "MSG16", "from": "P3", "to": "P4", "label": "storage_save(auth)", "type": "sync", "order": 16 },
      { "id": "MSG17", "from": "P4", "to": "P3", "label": "CLAUDE_OK", "type": "return", "order": 17 },
      { "id": "MSG18", "from": "P3", "to": "P2", "label": "return { ok, email, orgId }", "type": "return", "order": 18 },
      { "id": "MSG19", "from": "P2", "to": "P1", "label": "return auth result", "type": "return", "order": 19 }
    ],
    "fragments": [
      {
        "id": "FRAG1",
        "type": "alt",
        "label": "Token exchange fails (invalid code or verifier)",
        "messageRefs": ["MSG12", "MSG13"]
      }
    ]
  },
