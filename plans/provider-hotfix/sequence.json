        "type": "component",
        "componentRef": "CT2"
      },
      {
        "id": "P3",
        "name": "PostProcessingAutoHide",
        "type": "component",
        "componentRef": "C6"
      },
      {
        "id": "P4",
        "name": "ProviderRegistry",
        "type": "component",
        "componentRef": "CT2"
      }
    ],
    "messages": [
      {
        "id": "MSG1",
        "from": "P3",
