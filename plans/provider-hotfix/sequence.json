[
  {
    "diagram_title": "Codex Logout With Upstream Revoke",
    "scenario": "Operator triggers Account.remove for a codex-subscription account; daemon revokes upstream before clearing local state; fail-closed on error",
    "moduleRef": "A1",
    "participants": [
      {
        "id": "P1",
        "name": "Operator",
        "type": "actor",
        "componentRef": "SYS1"
      },
      {
        "id": "P2",
        "name": "Account.remove",
        "type": "component",
        "componentRef": "C2"
      },
      {
        "id": "P3",
        "name": "CodexAuth.logout",
        "type": "component",
        "componentRef": "C1"
      },
      {
        "id": "P4",
        "name": "OpenAI OAuth Edge",
        "type": "system",
        "componentRef": "SYS2"
      }
    ],
    "messages": [
      {
        "id": "MSG1",
        "from": "P1",
        "to": "P2",
        "label": "remove(codex, accountId)",
        "type": "sync",
        "order": 1
      },
      {
        "id": "MSG2",
        "from": "P2",
        "to": "P3",
        "label": "logout(accountId)",
        "type": "sync",
        "order": 2
      },
      {
        "id": "MSG3",
        "from": "P3",
        "to": "P4",
        "label": "POST /oauth/revoke token_type_hint=refresh_token",
        "type": "sync",
        "order": 3
      },
      {
        "id": "MSG4",
        "from": "P4",
        "to": "P3",
        "label": "2xx OR non-2xx",
        "type": "return",
        "order": 4
      },
      {
        "id": "MSG5",
        "from": "P3",
        "to": "P2",
        "label": "resolve OR throw RevokeError",
        "type": "return",
        "order": 5
      },
      {
        "id": "MSG6",
        "from": "P2",
        "to": "P2",
        "label": "clear local entry IF resolved else preserve",
        "type": "sync",
        "order": 6
      },
      {
        "id": "MSG7",
        "from": "P2",
        "to": "P1",
        "label": "success OR surfaced error",
        "type": "return",
        "order": 7
      }
    ],
    "fragments": [
      {
        "id": "FRAG1",
        "type": "alt",
        "label": "revoke_ok vs revoke_failed (fail-closed)",
        "messageRefs": ["MSG4", "MSG5", "MSG6"]
      }
    ]
  },
  {
