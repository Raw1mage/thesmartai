+    const errorDetails = (err: unknown) => {
+      if (!err || typeof err !== "object") return undefined
+      if ("data" in err) {
+        const data = (err as { data?: { statusCode?: number; message?: string; responseBody?: string } }).data
+        if (!data) return undefined
+        return {
+          status: data.statusCode,
+          message: data.message ?? "",
+          body: data.responseBody ?? "",
+        }
+      }
+      if (err instanceof Error) {
+        return {
+          status: undefined,
+          message: err.message,
+          body: "",
+        }
+      }
+      return undefined
+    }
+
+    const modelSwitchToast = (err: unknown) => {
+      const details = errorDetails(err)
+      if (!details) return undefined
+      const text = `${details.message} ${details.body}`.toLowerCase()
+      const rateLimited = details.status === 429 || text.includes("rate limit") || text.includes("too many requests")
+      const unauthorized = details.status === 401 || text.includes("unauthorized") || text.includes("authentication")
+      if (!rateLimited && !unauthorized) return undefined
+      const description = `${errorMessage(err)}. ${language.t("command.model.choose.description")}`
+      return { description }
+    }
