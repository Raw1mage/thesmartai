#!/usr/bin/env bash

# opencode-check-health - Delegate to the new opencode health-check CLI

echo "=== OpenCode Health Check (Legacy Wrapper) ==="
echo "Delegating to 'opencode health-check'..."

# Try to run via local source if in dev, otherwise via PATH
if [ -d "packages/opencode" ]; then
    bun run --cwd packages/opencode src/index.ts health-check "$@"
else
    opencode health-check "$@"
fi
