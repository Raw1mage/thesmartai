  {
    "id": "TV-R3a-1",
    "requirement": "R3",
    "scenario": "verbal trigger exact match (English)",
    "given": {
      "session": { "id": "S1" },
      "binding": { "slug": "foo" },
      "specState": "planned",
      "todos": [{ "id": "1.1", "status": "pending" }],
