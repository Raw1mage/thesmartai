  {
    "id": "TV-R6-1",
    "requirement": "R6",
    "scenario": "plan-amend during implementing demotes and disarms",
    "given": {
      "session": { "id": "S1" },
      "binding": { "slug": "foo" },
      "specState": "implementing",
      "armed": { "armed": true }
    },
    "when": "user runs `bun plan-promote specs/foo --mode amend --reason ...`",
    "then": {
      "r6DemoteFired": true,
      "historyAppended": { "from": "implementing", "to": "planned", "mode": "revise", "trigger_script": "plan-promote(amend)" },
      "specStateAfter": "planned",
      "armed": false,
      "armReason": "plan_edit_demotion",
      "amendAppliedAfterDemote": true
    }
  },
  {
    "id": "TV-R6-2",
    "requirement": "R6",
    "scenario": "checkbox toggle does NOT demote",
    "given": {
      "session": { "id": "S1" },
      "binding": { "slug": "foo" },
      "specState": "implementing",
      "armed": { "armed": true },
      "tasksMdBefore": "## 1. Phase\n- [ ] 1.1 do X",
      "tasksMdAfter": "## 1. Phase\n- [x] 1.1 do X"
    },
    "when": "agent toggles checkbox and plan-sync.ts runs",
    "then": {
      "specStateAfter": "implementing",
      "armed": true,
      "syncResult": "clean_or_checkbox_only"
    }
  }
