  {
    "id": "TV-R4-1",
    "requirement": "R4",
    "scenario": "phase rollover during armed execution",
    "given": {
      "session": { "id": "S1" },
      "binding": { "slug": "foo" },
      "specState": "implementing",
      "armed": { "armed": true },
      "todos": [{ "id": "1.1", "status": "completed" }, { "id": "1.2", "status": "completed" }],
      "tasksMd": "## 1. Phase One\n- [x] 1.1\n- [x] 1.2\n## 2. Phase Two\n- [ ] 2.1 do thing\n- [ ] 2.2 do another"
    },
    "when": "planAutonomousNextAction sees no actionable todo and armed==true",
    "then": {
      "refillInvoked": true,
      "newTodos": [{ "id": "2.1", "status": "pending" }, { "id": "2.2", "status": "pending" }],
      "armed": true,
      "busEvent": "autorun.refill"
    }
  },
  {
    "id": "TV-R4-2",
    "requirement": "R4",
    "scenario": "plan fully drained ends autorun",
    "given": {
      "session": { "id": "S1" },
      "armed": { "armed": true },
      "todos": [{ "id": "2.1", "status": "completed" }],
      "tasksMd": "## 1. Phase One\n- [x] 1.1\n## 2. Phase Two\n- [x] 2.1"
    },
    "when": "refill attempts to find next unchecked phase",
    "then": {
      "refillInvoked": true,
      "refillEmpty": true,
      "armed": false,
      "armReason": "plan_drained",
      "busEvent": "autorun.completed",
      "runnerResult": { "type": "stop", "reason": "plan_drained" }
    }
  },
  {
