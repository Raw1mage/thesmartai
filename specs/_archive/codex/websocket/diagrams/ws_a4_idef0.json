  "diagram_title": "Parse WS Events — Decomposition",
  "node_reference": "A4",
  "activities": [
    {
      "id": "A41",
      "title": "Parse Wrapped Websocket Error Event",
      "description": "Deserialize {type:'error', status:u16, error:{type,code,message,plan_type,resets_at}, headers:{...}}. Return None if type != 'error'",
      "decomposition": null
    },
    {
      "id": "A42",
      "title": "Map Error To Api Error",
      "description": "connection_limit_reached→Retryable(reconnect), usage_limit+status→Transport(Http{status,headers,body}), usage_limit_no_status→None(ignore), other+status→Transport",
      "decomposition": null
    },
    {
      "id": "A43",
      "title": "Parse Responses Stream Event",
      "description": "Deserialize JSON to ResponsesStreamEvent{kind,headers,response,item,delta,summary_index,content_index}. Shared format with SSE. On parse error: debug log, continue",
      "decomposition": null
    },
    {
      "id": "A44",
      "title": "Handle Codex Rate Limits Event",
      "description": "WS-specific: kind='codex.rate_limits'. Parse rate limit snapshot (plan_type, primary/secondary windows, credits). Emit RateLimits ResponseEvent",
      "decomposition": null
    },
    {
      "id": "A45",
      "title": "Track Server Model Changes",
      "description": "Extract model from response.headers or top-level headers (openai-model, x-openai-model). Compare with last_server_model. Emit ServerModel event on change",
      "decomposition": null
    },
    {
      "id": "A46",
      "title": "Detect Stream End",
      "description": "response.completed→Completed (normal end). response.incomplete→Stream error with reason. response.failed→error classification. All three terminate the stream loop",
      "decomposition": null
    }
  ],
