[
  {
    "id": "S0",
    "name": "Entry",
    "type": "initial",
    "description": "run() called with RunInput",
    "actions": ["Parse RunInput", "Look up KIND_CHAIN[observed] and INJECT_CONTINUE[observed]"]
  },
  {
    "id": "S1",
    "name": "CooldownCheck",
    "description": "Consult Cooldown.shouldThrottle(sid, step, threshold)",
    "actions": ["Read Memory.lastCompactedAt", "Compare step - lastRound vs threshold"]
  },
  {
    "id": "S2",
    "name": "AttemptKind",
    "description": "Try the next kind in KIND_CHAIN (entered repeatedly until a kind succeeds or chain exhausted)",
    "actions": ["Pick next kind from chain", "Evaluate kind's availability predicate", "Invoke kind's executor if available"]
  },
  {
    "id": "S3",
    "name": "WriteAnchor",
    "description": "Executor returned summary text; write Anchor to message stream",
    "actions": ["Append assistant message with summary:true", "Append part of type 'compaction' with kind metadata"]
  },
  {
    "id": "S4",
    "name": "MaybeInjectContinue",
    "description": "Conditional branch based on INJECT_CONTINUE[observed]",
    "actions": ["If injectContinue: append synthetic user message with text 'Continue if you have next steps...'"]
  },
  {
    "id": "S5",
    "name": "MarkCompacted",
    "description": "Update Memory.lastCompactedAt for cooldown",
    "actions": ["Memory.markCompacted(sid, {round: step, timestamp: now})"]
  },
  {
    "id": "S6",
    "name": "SuccessExit",
    "type": "final",
    "description": "Return 'continue' to caller",
    "actions": ["log.info kind=<chosen> succeeded"]
  },
  {
    "id": "S7",
    "name": "ChainExhausted",
    "description": "All kinds in chain failed or were unavailable",
    "actions": ["log.warn 'all kinds exhausted for observed=<...>'"]
  },
  {
    "id": "S8",
    "name": "StopExit",
    "type": "final",
    "description": "Return 'stop' to caller",
    "actions": ["No anchor written", "Cooldown not updated"]
  },
  {
    "id": "S9",
    "name": "ThrottledExit",
    "type": "final",
    "description": "Return 'continue' immediately; cooldown blocked execution",
    "actions": ["log.info 'compaction throttled by cooldown'", "Skip kind chain"]
  },
  {
    "id": "T01",
    "type": "transition",
    "from": "S0",
    "to": "S1",
    "condition": "always",
    "description": "Initial entry"
  },
  {
    "id": "T19",
    "type": "transition",
    "from": "S1",
    "to": "S9",
    "condition": "shouldThrottle == true",
    "description": "Cooldown active, abort"
  },
  {
    "id": "T12",
    "type": "transition",
    "from": "S1",
    "to": "S2",
    "condition": "shouldThrottle == false",
    "description": "Begin kind-chain walk"
  },
  {
    "id": "T23",
    "type": "transition",
    "from": "S2",
    "to": "S3",
    "condition": "kind executor returned summary text",
    "description": "Kind succeeded; proceed to anchor write"
  },
  {
    "id": "T22",
    "type": "transition",
    "from": "S2",
    "to": "S2",
    "condition": "kind unavailable OR returned null AND chain has more entries",
    "description": "Self-loop: try next kind. Each transition emits log.info with attempted kind and reason for falling through (AGENTS.md rule 1)."
  },
  {
    "id": "T27",
    "type": "transition",
    "from": "S2",
    "to": "S7",
    "condition": "chain exhausted (all kinds tried, none succeeded)",
    "description": "No kind worked"
  },
  {
    "id": "T34",
    "type": "transition",
    "from": "S3",
    "to": "S4",
    "condition": "anchor written",
    "description": "Proceed to optional Continue injection"
  },
  {
    "id": "T45",
    "type": "transition",
    "from": "S4",
    "to": "S5",
    "condition": "always (whether or not Continue was injected)",
    "description": "Mark compacted regardless"
  },
  {
    "id": "T56",
    "type": "transition",
    "from": "S5",
    "to": "S6",
    "condition": "always",
    "description": "Success path complete"
  },
  {
    "id": "T78",
    "type": "transition",
    "from": "S7",
    "to": "S8",
    "condition": "always",
    "description": "Chain exhaustion → stop result"
  }
]
