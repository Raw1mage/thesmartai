  {
    "diagram_title": "Non-Blocking Request Accept and HTTP Buffering",
    "scenario": "A TCP connection arrives and is buffered incrementally until a complete HTTP header is assembled.",
    "moduleRef": "A1",
    "participants": [
      { "id": "P1", "name": "Browser", "type": "actor" },
      { "id": "P2", "name": "epoll Loop", "type": "component", "componentRef": "C1" },
      { "id": "P3", "name": "HTTP Accumulator", "type": "component", "componentRef": "C2" }
    ],
    "messages": [
      { "id": "M1", "from": "P1", "to": "P2", "label": "TCP SYN → accept4(SOCK_CLOEXEC)", "type": "sync", "order": 1 },
      { "id": "M2", "from": "P2", "to": "P3", "label": "allocate PendingRequest, register fd as EPOLL_PENDING", "type": "sync", "order": 2 },
      { "id": "M3", "from": "P2", "to": "P2", "label": "return to epoll_wait (non-blocking)", "type": "sync", "order": 3 },
      { "id": "M4", "from": "P1", "to": "P3", "label": "EPOLLIN: TCP segment 1 (partial header)", "type": "sync", "order": 4 },
      { "id": "M5", "from": "P3", "to": "P3", "label": "append to buffer, check for \\r\\n\\r\\n → not found", "type": "sync", "order": 5 },
      { "id": "M6", "from": "P1", "to": "P3", "label": "EPOLLIN: TCP segment 2 (header complete)", "type": "sync", "order": 6 },
      { "id": "M7", "from": "P3", "to": "P2", "label": "header complete → route to auth/JWT/login handler", "type": "return", "order": 7 }
    ],
    "fragments": [
      { "id": "F1", "type": "loop", "label": "accumulate until header complete or timeout/oversize", "messageRefs": ["M4", "M5", "M6"] }
    ]
  },
  {
    "diagram_title": "Thread-Per-Auth PAM Login",
    "scenario": "A login request is rate-checked, then PAM authentication runs in a separate thread without blocking the epoll loop.",
    "moduleRef": "A2",
    "participants": [
      { "id": "P1", "name": "Browser", "type": "actor" },
      { "id": "P2", "name": "epoll Loop", "type": "component", "componentRef": "C1" },
      { "id": "P3", "name": "Rate Limiter", "type": "component", "componentRef": "C3" },
      { "id": "P4", "name": "PAM Thread", "type": "component", "componentRef": "C3" },
      { "id": "P5", "name": "JWT Engine", "type": "component", "componentRef": "C4" }
    ],
    "messages": [
      { "id": "M1", "from": "P2", "to": "P3", "label": "check per-IP failure count", "type": "sync", "order": 1 },
      { "id": "M2", "from": "P3", "to": "P2", "label": "under limit → proceed", "type": "return", "order": 2 },
      { "id": "M3", "from": "P2", "to": "P4", "label": "spawn pthread(pam_authenticate)", "type": "async", "order": 3 },
      { "id": "M4", "from": "P2", "to": "P2", "label": "return to epoll_wait (loop not blocked)", "type": "sync", "order": 4 },
      { "id": "M5", "from": "P4", "to": "P2", "label": "eventfd signal: PAM result ready", "type": "async", "order": 5 },
      { "id": "M6", "from": "P2", "to": "P5", "label": "PAM success → sign JWT with file-backed secret", "type": "sync", "order": 6 },
      { "id": "M7", "from": "P5", "to": "P1", "label": "200 + Set-Cookie: oc_jwt=... + meta-refresh", "type": "sync", "order": 7 }
    ],
    "fragments": [
      { "id": "F1", "type": "alt", "label": "rate limit pass vs reject (429)", "messageRefs": ["M1", "M2"] },
      { "id": "F2", "type": "alt", "label": "PAM success (sign JWT) vs PAM fail (increment counter)", "messageRefs": ["M5", "M6"] }
    ]
  },
