{
  "diagram_title": "Operate Unified Message Bus",
  "node_reference": "A0",
  "activities": [
    {
      "id": "A1",
      "title": "Publish Event To Topic",
      "description": "Validate event props against zod schema and dispatch to all topic subscribers. Entry point for 124 Bus.publish sites + 318 debugCheckpoint sites via Bus.debug wrapper.",
      "decomposition": "A1"
    },
    {
      "id": "A2",
      "title": "Route To Backend Subscribers",
      "description": "Execute registered backend subscriber callbacks: debug-writer (debug.log), tui-toaster (TUI toast). Each subscriber applies its own logLevel gate.",
      "decomposition": "A2"
    },
    {
      "id": "A3",
      "title": "Transport To Frontend Via SSE",
      "description": "GlobalBus SSE transport adapter — wildcard subscriber that relays all events to frontend via Hono streamSSE endpoint /api/v2/global/event.",
      "decomposition": null
    },
    {
      "id": "A4",
      "title": "Route Frontend Events To Components",
      "description": "Broadcast-first delivery to all children stores. Frontend subscribers (webapp toaster, LLM card, session list) process events via event-reducer.",
      "decomposition": null
    },
    {
      "id": "A5",
      "title": "Migrate Legacy Event Callers",
      "description": "Backward-compatible wrappers: debugCheckpoint() → Bus.debug(), GlobalBus.emit() → Bus.publish(), TuiEvent.ToastShow → tui-toaster subscriber.",
      "decomposition": null
    }
  ],
