      { "id": "MSG3",  "from": "uphook",        "to": "docxmcp_fast",   "label": "extract_all(token=foo) [fast phase, sync, 30 s timeout]" },
      { "id": "MSG4",  "from": "docxmcp_fast",  "to": "docxmcp_fast",   "label": "write outline.md + template/* + manifest{background_status:running, pending_kinds:[body,chapter,table,media]} + _PENDING.md markers in chapters/, tables/, media/" },
      { "id": "MSG5",  "from": "docxmcp_fast",  "to": "docxmcp_bg",     "label": "double-fork detached child" },
      { "id": "MSG6",  "from": "docxmcp_fast",  "to": "uphook",         "label": "fast tar bundle (outline + template + manifest + markers)" },
      { "id": "MSG7",  "from": "uphook",        "to": "uphook",         "label": "extract bundle into incoming/foo/" },
      { "id": "MSG8",  "from": "uphook",        "to": "polling",        "label": "schedule poll every 5 s; cap 180 s" },
      { "id": "MSG9",  "from": "uphook",        "to": "composer",       "label": "manifest path; render hint" },
      { "id": "MSG10", "from": "composer",      "to": "ai",             "label": "user message + routing hint (banner '⏳ 背景拆解中', pull-refresh contract per DD-13)" },
      { "id": "MSG11", "from": "ai",            "to": "ai",             "label": "read incoming/foo/manifest.json (per DD-13) → bg=running → read incoming/foo/outline.md to start summary" },
      { "id": "MSG12", "from": "docxmcp_bg",    "to": "docxmcp_bg",     "label": "(in container) write body.md, then chapters/01-…, 02-…, 03-…, tables/01.csv, …, media/…" },
      { "id": "MSG13", "from": "polling",       "to": "docxmcp_collect","label": "[T+5s] extract_all_collect(wait=0)" },
      { "id": "MSG14", "from": "docxmcp_collect","to": "polling",       "label": "incremental bundle (body.md + chapters/01-, /02-, tables/01.csv) + manifest{bg:running}" },
      { "id": "MSG15", "from": "polling",       "to": "polling",        "label": "publish increment into incoming/foo/" },
      { "id": "MSG16", "from": "polling",       "to": "docxmcp_collect","label": "[T+10s] extract_all_collect(wait=0)" },
      { "id": "MSG17", "from": "docxmcp_collect","to": "polling",       "label": "incremental bundle (chapters/03-, media/05-, …) + manifest{bg:running}" },
      { "id": "MSG18", "from": "docxmcp_bg",    "to": "docxmcp_bg",     "label": "(in container) finish; rewrite manifest{bg:done, duration_ms_bg:46000}; remove _PENDING.md markers" },
      { "id": "MSG19", "from": "polling",       "to": "docxmcp_collect","label": "[T+15s] extract_all_collect(wait=0)" },
      { "id": "MSG20", "from": "docxmcp_collect","to": "polling",       "label": "final bundle (manifest{bg:done} + last extras) + marker removals" },
      { "id": "MSG21", "from": "polling",       "to": "polling",        "label": "manifest.bg=done → stop polling" },
      { "id": "MSG22", "from": "ai",            "to": "ai",             "label": "[next AI turn] user asks 'show me chapter 3' → re-read manifest (DD-13) → bg=done, chapters/03-*.md present → read it" },
      { "id": "MSG23", "from": "ai",            "to": "user",           "label": "summary reply" }
    ]
  },
