    "participants": [
      { "id": "user", "name": "User" },
      { "id": "uphook", "name": "User-Message Upload Hook", "componentRef": "T1" },
      { "id": "polling", "name": "Polling Loop", "componentRef": "T1b" },
      { "id": "docxmcp_fast", "name": "docxmcp extract_all (fast)", "componentRef": "T5" },
      { "id": "docxmcp_bg", "name": "docxmcp background child", "componentRef": "T5b" },
      { "id": "docxmcp_collect", "name": "docxmcp extract_all_collect", "componentRef": "T5c" },
      { "id": "composer", "name": "Routing Hint Renderer", "componentRef": "T2" },
      { "id": "ai", "name": "AI session" }
    ],
    "messages": [
      { "id": "MSG1",  "from": "user",          "to": "uphook",         "label": "POST upload (foo.docx, '幫我摘要')" },
