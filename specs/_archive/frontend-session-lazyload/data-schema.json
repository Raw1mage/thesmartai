{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "frontend-session-lazyload data contracts",
  "definitions": {
    "SessionMetaResponse": {
      "type": "object",
      "description": "GET /session/:id/meta 回應",
      "required": ["partCount", "totalBytes", "lastUpdated", "etag"],
      "additionalProperties": false,
      "properties": {
        "partCount": {
          "type": "integer",
          "minimum": 0,
          "description": "該 session 所有 message 內 part 檔案的總數量"
        },
        "totalBytes": {
          "type": "integer",
          "minimum": 0,
          "description": "所有 part 檔案的磁碟大小總和（bytes）"
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time",
          "description": "最新一次 part / message / session 變更時間"
        },
        "etag": {
          "type": "string",
          "description": "對應 session:{id}:meta 的 ETag；與 session:{id} 版本掛勾"
        },
        "messageCount": {
          "type": "integer",
          "minimum": 0,
          "description": "message 數量（非必要欄位；便於 client 判斷是否超過 initial_page_size）"
        }
      }
    },
    "TweaksConfigKeys": {
      "type": "object",
      "description": "新增於 /etc/opencode/tweaks.cfg 的 keys",
      "required": [
        "frontend_session_lazyload",
        "part_inline_cap_kb",
        "tail_window_kb",
        "fold_preview_lines",
        "initial_page_size_small",
        "initial_page_size_medium",
        "initial_page_size_large",
        "session_size_threshold_kb",
        "session_size_threshold_parts",
        "sse_reconnect_replay_max_events",
        "sse_reconnect_replay_max_age_sec",
        "session_messages_default_tail"
      ],
      "properties": {
        "frontend_session_lazyload": {
          "type": "integer",
          "enum": [0, 1],
          "default": 0,
          "description": "整套新行為的總開關；0=舊路徑、1=新路徑"
        },
        "part_inline_cap_kb": {
          "type": "integer",
          "minimum": 4,
          "maximum": 4096,
          "default": 64,
          "description": "單一 part 超過此大小即預設收合"
        },
        "tail_window_kb": {
          "type": "integer",
          "minimum": 4,
          "maximum": 4096,
          "default": 64,
          "description": "Streaming 中 part 只保留最後 N KB"
        },
        "fold_preview_lines": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200,
          "default": 20,
          "description": "折疊狀態下顯示前 N 行"
        },
        "initial_page_size_small": {
          "type": "string",
          "default": "all",
          "description": "partCount ≤ 50 時的初始載入量；all / 數字皆可"
        },
        "initial_page_size_medium": {
          "type": "integer",
          "minimum": 10,
          "maximum": 1000,
          "default": 100,
          "description": "partCount 51–200 時初始載入 message 數"
        },
        "initial_page_size_large": {
          "type": "integer",
          "minimum": 10,
          "maximum": 1000,
          "default": 50,
          "description": "partCount > 200 時初始載入 message 數"
        },
        "session_size_threshold_kb": {
          "type": "integer",
          "minimum": 64,
          "default": 512,
          "description": "首頁 auto-redirect 的 bytes 門檻；超過則走 /sessions"
        },
        "session_size_threshold_parts": {
          "type": "integer",
          "minimum": 10,
          "default": 80,
          "description": "首頁 auto-redirect 的 part 數門檻；超過則走 /sessions"
        },
        "sse_reconnect_replay_max_events": {
          "type": "integer",
          "minimum": 10,
          "maximum": 1000,
          "default": 100,
          "description": "(R8, ADDED 2026-04-22) SSE reconnect handshake 最多 replay 的事件數；超過則裁到 tail N 筆並發 sync.required"
        },
        "sse_reconnect_replay_max_age_sec": {
          "type": "integer",
          "minimum": 5,
          "maximum": 600,
          "default": 60,
          "description": "(R8, ADDED 2026-04-22) SSE reconnect handshake replay 的時間窗口秒數；超過此齡的事件跳過，缺口以 sync.required 告知"
        },
        "session_messages_default_tail": {
          "type": "integer",
          "minimum": 5,
          "maximum": 200,
          "default": 30,
          "description": "(R9, ADDED 2026-04-22) 無 beforeMessageID 的 GET /:id/message 預設回 tail N 則；前端 cold open 首屏大小"
        }
      }
    },
    "SessionMessagesQuery": {
      "type": "object",
      "description": "(R9, ADDED 2026-04-22) GET /session/:id/message query params",
      "additionalProperties": false,
      "properties": {
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "description": "本頁筆數。無 beforeMessageID 時 default = session_messages_default_tail，有 beforeMessageID 時 default 同值"
        },
        "beforeMessageID": {
          "type": "string",
          "description": "cursor：回比此 messageID 更舊（time.created 更早）的 limit 筆；無此參數回最新 tail"
        },
        "since": {
          "type": "string",
          "format": "date-time",
          "description": "既有 incremental tail fetch 參數；本 revise 不動其語意但要求 CMS proxy 完整透傳"
        }
      }
    },
    "SSEReplayHandshakeResult": {
      "type": "object",
      "description": "(R8, ADDED 2026-04-22) sseGetBoundedSince 純函式回傳",
      "required": ["events", "droppedCount", "droppedBoundary"],
      "properties": {
        "events": {
          "type": "array",
          "description": "要 writeSSE 送出的事件列表（已裁切）",
          "items": {
            "type": "object",
            "required": ["id", "event", "receivedAt"],
            "properties": {
              "id": { "type": "integer" },
              "event": {},
              "receivedAt": { "type": "integer", "description": "wall-clock ms" }
            }
          }
        },
        "droppedCount": {
          "type": "integer",
          "minimum": 0,
          "description": "被裁掉的事件數"
        },
        "droppedBoundary": {
          "type": ["string", "null"],
          "enum": ["count", "age", null],
          "description": "由哪個窗口觸發裁切：count 數量上限 / age 時間上限 / null 無裁切"
        }
      }
    },
    "PartStore": {
      "type": "object",
      "description": "前端 store.part[id] 的擴充欄位",
      "required": ["id", "type", "text"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "tool", "reasoning", "file", "agent"] },
        "text": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["streaming", "completed"],
          "description": "決定 MessagePart 用 tail-window 還是 fold UI"
        },
        "truncatedPrefix": {
          "type": "integer",
          "minimum": 0,
          "description": "Streaming 中被截掉的前段 bytes 數；streaming 完成後需從 server 重拉才可恢復"
        }
      }
    },
    "LazyloadTelemetryEvent": {
      "type": "object",
      "description": "推到 observability pipeline 的事件",
      "required": ["event", "at"],
      "properties": {
        "event": {
          "type": "string",
          "enum": [
            "lazyload.meta.call",
            "lazyload.meta.fail",
            "lazyload.threshold.exceeded",
            "lazyload.loadmore.trigger",
            "lazyload.loadmore.complete",
            "lazyload.part.fold",
            "lazyload.part.expand",
            "lazyload.streaming.tail",
            "lazyload.rebuild.detected",
            "lazyload.rebuild.mismatch",
            "lazyload.flag.state",
            "sse.replay.handshake",
            "sse.replay.sync_required",
            "messages.cursor.fetch",
            "messages.cursor.exhausted"
          ]
        },
        "at": { "type": "string", "format": "date-time" },
        "sessionID": { "type": "string" },
        "partID": { "type": "string" },
        "partCount": { "type": "integer" },
        "totalBytes": { "type": "integer" },
        "flag": { "type": "integer", "enum": [0, 1] },
        "details": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
