{
  "diagram_title": "A62 — 管理 Per-User Daemon",
  "node_reference": "A62",
  "activities": [
    {
      "id": "A621",
      "title": "取得 Gateway 鎖",
      "description": "寫入 PID 至 daemon.pid，確保每用戶唯一 daemon 實例。Spawn-first-wins 競爭模型。",
      "decomposition": null
    },
    {
      "id": "A622",
      "title": "註冊信號處理",
      "description": "綁定 SIGTERM（graceful shutdown）、SIGINT（立即停止）、SIGUSR1（restart trigger）。路由至對應狀態機。",
      "decomposition": null
    },
    {
      "id": "A623",
      "title": "管理命令車道",
      "description": "Per-workspace 並行佇列。車道分級：critical (max 4)、normal (max 3)、background (max 1)。FIFO 調度。",
      "decomposition": null
    },
    {
      "id": "A624",
      "title": "執行排水狀態機",
      "description": "Drain 模式：停止接受新請求，等待進行中車道 idle（5s timeout），完成後釋放資源。",
      "decomposition": null
    },
    {
      "id": "A625",
      "title": "協調重啟序列",
      "description": "SIGUSR1 觸發 restart：drain → release lock → re-acquire → re-init。Generation 遞增防止 stale 引用。",
      "decomposition": null
    }
  ],
