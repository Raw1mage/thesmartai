  {
    "diagram_title": "Post-task sync check (warn strategy)",
    "scenario": "beta-workflow just checked off a task; auto-invokes plan-sync to detect code-spec drift, warns but does not block",
    "moduleRef": "A5",
    "participants": [
      { "id": "P1", "name": "beta-workflow", "type": "system", "componentRef": "SYS3" },
      { "id": "P2", "name": "plan-sync.ts", "type": "component", "componentRef": "C14" },
      { "id": "P3", "name": "Repo FS (git)", "type": "system", "componentRef": "SYS2" }
    ],
    "messages": [
      { "id": "MSG1", "from": "P1", "to": "P2", "label": "bun run plan-sync.ts specs/{slug}/ (after task checkbox toggle)", "type": "sync", "order": 1 },
      { "id": "MSG2", "from": "P2", "to": "P3", "label": "git diff since last sync-aligned commit", "type": "sync", "order": 2 },
      { "id": "MSG3", "from": "P3", "to": "P2", "label": "changed files + hunks", "type": "return", "order": 3 },
      { "id": "MSG4", "from": "P2", "to": "P3", "label": "read data-schema.json / errors.md / test-vectors.json to detect drift", "type": "sync", "order": 4 },
      { "id": "MSG5", "from": "P2", "to": "P1", "label": "[plan-sync] WARN: drift in user.session.lastActive (suggest amend mode)", "type": "return", "order": 5 },
      { "id": "MSG6", "from": "P2", "to": "P3", "label": "write .state.json.history += {mode:sync, result:warned, drift:[...]}", "type": "sync", "order": 6 },
      { "id": "MSG7", "from": "P2", "to": "P1", "label": "exit 0 (non-blocking)", "type": "return", "order": 7 }
    ],
    "fragments": [
      { "id": "FRAG1", "type": "alt", "label": "No drift detected — write history {result:clean} + exit 0", "messageRefs": ["MSG5", "MSG6"] }
    ]
  },
