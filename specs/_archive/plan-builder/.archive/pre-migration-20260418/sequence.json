      { "id": "P5", "name": "Repo FS (git)", "type": "system", "componentRef": "SYS2" }
    ],
    "messages": [
      { "id": "MSG1", "from": "P1", "to": "P2", "label": "bun run plan-promote.ts --mode refactor specs/{slug}/", "type": "sync", "order": 1 },
