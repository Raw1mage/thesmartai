[
  {
    "diagram_title": "New spec creation (new mode)",
    "scenario": "User asks plan-builder to create a brand-new spec; skill scaffolds proposal.md and .state.json, state=proposed",
    "moduleRef": "A4",
    "participants": [
      { "id": "P1", "name": "User", "type": "actor", "componentRef": "C1" },
      { "id": "P2", "name": "plan-init.ts", "type": "component", "componentRef": "C2" },
      { "id": "P3", "name": "templates/", "type": "component", "componentRef": "C12" },
      { "id": "P4", "name": "Repo FS", "type": "system", "componentRef": "SYS2" }
    ],
    "messages": [
      { "id": "MSG1", "from": "P1", "to": "P2", "label": "bun run plan-init.ts <slug>", "type": "sync", "order": 1 },
      { "id": "MSG2", "from": "P2", "to": "P3", "label": "read proposal template", "type": "sync", "order": 2 },
      { "id": "MSG3", "from": "P3", "to": "P2", "label": "template content", "type": "return", "order": 3 },
      { "id": "MSG4", "from": "P2", "to": "P4", "label": "write specs/<slug>/proposal.md", "type": "sync", "order": 4 },
      { "id": "MSG5", "from": "P2", "to": "P4", "label": "write specs/<slug>/.state.json {state:proposed, history:[created]}", "type": "sync", "order": 5 },
      { "id": "MSG6", "from": "P2", "to": "P1", "label": "log: created specs/<slug>/ at state=proposed", "type": "return", "order": 6 }
    ],
    "fragments": []
  },
  {
    "diagram_title": "State query with on-touch migration",
    "scenario": "User runs plan-state against a legacy plans/<slug>/; script auto-migrates then reports inferred state",
    "moduleRef": "A1",
    "participants": [
      { "id": "P1", "name": "User", "type": "actor", "componentRef": "C1" },
      { "id": "P2", "name": "plan-state.ts", "type": "component", "componentRef": "C3" },
      { "id": "P3", "name": "ensure-new-format.ts", "type": "component", "componentRef": "C9" },
      { "id": "P4", "name": "state-inference.ts", "type": "component", "componentRef": "C10" },
      { "id": "P5", "name": "Repo FS (git)", "type": "system", "componentRef": "SYS2" }
    ],
    "messages": [
      { "id": "MSG1", "from": "P1", "to": "P2", "label": "bun run plan-state.ts plans/<slug>/", "type": "sync", "order": 1 },
      { "id": "MSG2", "from": "P2", "to": "P3", "label": "ensureNewFormat(path)", "type": "sync", "order": 2 },
      { "id": "MSG3", "from": "P3", "to": "P5", "label": "detect: no .state.json + path in plans/", "type": "sync", "order": 3 },
      { "id": "MSG4", "from": "P3", "to": "P4", "label": "inferState(path)", "type": "sync", "order": 4 },
      { "id": "MSG5", "from": "P4", "to": "P5", "label": "read artifacts to match inference rules", "type": "sync", "order": 5 },
      { "id": "MSG6", "from": "P4", "to": "P3", "label": "inferred state (e.g. implementing)", "type": "return", "order": 6 },
      { "id": "MSG7", "from": "P3", "to": "P5", "label": "snapshot to specs/<slug>/.archive/pre-migration-YYYYMMDD/", "type": "sync", "order": 7 },
      { "id": "MSG8", "from": "P3", "to": "P5", "label": "git mv plans/<slug>/ specs/<slug>/", "type": "sync", "order": 8 },
      { "id": "MSG9", "from": "P3", "to": "P5", "label": "write .state.json {state:implementing, history:[migration]}", "type": "sync", "order": 9 },
      { "id": "MSG10", "from": "P3", "to": "P1", "label": "log every migration step with [plan-builder-migrate] prefix", "type": "async", "order": 10 },
      { "id": "MSG11", "from": "P3", "to": "P2", "label": "migration complete, return", "type": "return", "order": 11 },
      { "id": "MSG12", "from": "P2", "to": "P5", "label": "read .state.json.state", "type": "sync", "order": 12 },
      { "id": "MSG13", "from": "P2", "to": "P1", "label": "current state: implementing", "type": "return", "order": 13 }
    ],
    "fragments": [
      { "id": "FRAG1", "type": "alt", "label": "Format is already new (.state.json exists) — skip migration", "messageRefs": ["MSG3"] },
      { "id": "FRAG2", "type": "alt", "label": "State inference fails — throw StateInferenceError (no default)", "messageRefs": ["MSG4", "MSG5", "MSG6"] }
    ]
  },
  {
    "diagram_title": "State promotion with validation gate",
    "scenario": "User promotes spec from designed to planned; script validates artifact requirements before writing history",
    "moduleRef": "A1",
    "participants": [
      { "id": "P1", "name": "User", "type": "actor", "componentRef": "C1" },
      { "id": "P2", "name": "plan-promote.ts", "type": "component", "componentRef": "C4" },
      { "id": "P3", "name": "plan-validate.ts", "type": "component", "componentRef": "C5" },
      { "id": "P4", "name": "state.schema.json", "type": "component", "componentRef": "C11" },
      { "id": "P5", "name": "Repo FS", "type": "system", "componentRef": "SYS2" }
    ],
    "messages": [
      { "id": "MSG1", "from": "P1", "to": "P2", "label": "bun run plan-promote.ts <path> --to planned", "type": "sync", "order": 1 },
      { "id": "MSG2", "from": "P2", "to": "P5", "label": "read current .state.json", "type": "sync", "order": 2 },
      { "id": "MSG3", "from": "P2", "to": "P3", "label": "validate artifacts required for target state (planned)", "type": "sync", "order": 3 },
      { "id": "MSG4", "from": "P3", "to": "P5", "label": "check tasks.md, handoff.md, test-vectors.json, errors.md, observability.md", "type": "sync", "order": 4 },
      { "id": "MSG5", "from": "P3", "to": "P2", "label": "validation result", "type": "return", "order": 5 },
      { "id": "MSG6", "from": "P2", "to": "P4", "label": "validate new .state.json shape", "type": "sync", "order": 6 },
      { "id": "MSG7", "from": "P2", "to": "P5", "label": "write .state.json {state:planned, history:+[promote]}", "type": "sync", "order": 7 },
      { "id": "MSG8", "from": "P2", "to": "P1", "label": "promoted to planned", "type": "return", "order": 8 }
    ],
    "fragments": [
      { "id": "FRAG1", "type": "alt", "label": "Validation fails — promotion rejected, state unchanged", "messageRefs": ["MSG5"] },
      { "id": "FRAG2", "type": "alt", "label": "Transition is illegal (e.g. proposed → implementing) — reject with reason", "messageRefs": ["MSG2"] }
    ]
  },
  {
