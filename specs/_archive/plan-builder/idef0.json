      "decomposition": null
    },
    {
      "id": "A5",
      "title": "Analyze Code-Independence Gaps",
      "description": "掃描 spec 是否有缺 schema、缺 test-vectors、abstract GWT、缺 errors 等 code-independence 漏洞",
      "decomposition": null
    },
    {
      "id": "A6",
      "title": "Archive Spec",
      "description": "將 spec 推進到 archived 狀態並可選地搬移至 specs/archive/ 資料夾",
      "decomposition": null
    }
