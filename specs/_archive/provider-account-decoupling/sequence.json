      { "id": "MSG5.7", "from": "C6.2", "to": "filesystem", "payload": "atomic rename rewrite providerId=\"codex\"" },
      { "id": "MSG5.8", "from": "migrate script", "to": "C5.1", "payload": "sanity-check accounts.json (every families key in knownFamilies); fail loud if not" },
      { "id": "MSG5.9", "from": "migrate script", "to": "C6.3 marker-writer", "payload": "write .migration-state.json {version:1, migrated_at, backup_path}" }
