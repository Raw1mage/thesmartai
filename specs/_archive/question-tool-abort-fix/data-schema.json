{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://opencode.local/specs/question-tool-abort-fix/data-schema.json",
  "title": "Data schema for question-tool-abort-fix",
  "description": "Canonical data contract for the question abort / cache key / cancel telemetry changes.",
  "type": "object",
  "definitions": {
    "CancelReason": {
      "type": "string",
      "enum": [
        "manual-stop",
        "rate-limit-fallback",
        "monitor-watchdog",
        "instance-dispose",
        "replace",
        "session-switch",
        "unknown"
      ],
      "description": "Canonical reason string for prompt-runtime cancel / AbortController.abort. All callers must supply a value from this enum."
    },
    "QuestionAskInput": {
      "type": "object",
      "required": ["sessionID", "questions"],
      "properties": {
        "sessionID": { "type": "string" },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/QuestionInfo" }
        },
        "tool": {
          "type": "object",
          "properties": {
            "messageID": { "type": "string" },
            "callID": { "type": "string" }
          },
          "required": ["messageID", "callID"]
        },
        "abort": {
          "type": "object",
          "description": "Optional AbortSignal. When provided, abort fires auto-reject of pending question.",
          "properties": {
            "aborted": { "type": "boolean" },
            "reason": { "type": ["string", "object"] }
          }
        }
      }
    },
    "QuestionInfo": {
      "type": "object",
      "required": ["question", "header", "options"],
      "properties": {
        "question": { "type": "string" },
        "header": { "type": "string" },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "description": { "type": "string" }
            },
            "required": ["label", "description"]
          }
        },
        "multiple": { "type": "boolean" },
        "custom": { "type": "boolean" }
      }
    },
    "PendingEntry": {
      "type": "object",
      "description": "Shape of Question.pending[id] after this change",
      "required": ["info", "resolve", "reject"],
      "properties": {
        "info": { "type": "object" },
        "resolve": { "type": "object", "description": "answers → void fn" },
        "reject": { "type": "object", "description": "any → void fn" },
        "dispose": {
          "type": "object",
          "description": "Optional teardown fn removing abort listener; called inside reply/reject paths"
        }
      }
    },
    "QuestionDockCacheEntry": {
      "type": "object",
      "required": ["tab", "answers", "custom"],
      "properties": {
        "tab": { "type": "integer", "minimum": 0 },
        "answers": {
          "type": "array",
          "items": { "type": "array", "items": { "type": "string" } }
        },
        "custom": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "QuestionDockCacheKey": {
      "type": "string",
      "pattern": "^ses_[a-zA-Z0-9]+:[a-f0-9]{40}$",
      "description": "Format: <sessionID>:<SHA-1 hex of canonical JSON(questions)>"
    },
    "CancelLogEntry": {
      "type": "object",
      "required": ["sessionID", "reason"],
      "properties": {
        "sessionID": { "type": "string" },
        "reason": { "$ref": "#/definitions/CancelReason" },
        "caller": {
          "type": "string",
          "description": "First non-framework stack frame, e.g. 'at SessionPromptDock.onStop (session-prompt-dock.tsx:105:43)'"
        }
      }
    }
  },
  "properties": {}
}
