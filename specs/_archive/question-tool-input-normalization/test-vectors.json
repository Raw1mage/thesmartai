  {
    "id": "TV-13",
    "requirementRef": "Shared normalize helper is the single source of truth",
    "scenarioRef": "no silent fallback on un-normalizable input",
    "input": {
      "helper_input_cases": [null, 42, "string", {}, []]
    },
    "expected": {
      "null_result": null,
      "number_result": 42,
      "string_result": "string",
      "emptyObject_result": {},
      "emptyArray_result": [],
      "notableBehavior": "helper is pure; never throws; consumer sees raw when it cannot be classified"
    }
  },
  {
    "id": "TV-14",
    "requirementRef": "Shared normalize helper is the single source of truth",
    "scenarioRef": "option with value/detail keys gets coerced to label/description",
    "input": {
      "raw_option": { "value": "A", "detail": "The first choice" }
    },
    "expected": {
      "normalized_option": { "label": "A", "description": "The first choice", "value": "A", "detail": "The first choice" }
    }
  },
  {
    "id": "TV-15",
    "requirementRef": "UI renderers defensively normalize legacy raw shape",
    "scenarioRef": "TUI Question component mirrors behavior",
