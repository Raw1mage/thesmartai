[
  {
    "id": "TV-1",
    "requirementRef": "Tool.define guarantees execute receives parsed args",
    "scenarioRef": "z.preprocess transform is honored",
    "input": {
      "toolParameters_pseudocode": "z.preprocess(raw => ({foo: raw.bar}), z.object({foo: z.string()}))",
      "llmArgs": { "bar": "x" }
    },
    "expected": {
      "executeArgs": { "foo": "x" }
    }
  },
  {
    "id": "TV-2",
    "requirementRef": "Tool.define guarantees execute receives parsed args",
    "scenarioRef": "canonical input passes through unchanged",
    "input": {
      "toolParameters_pseudocode": "z.preprocess(identity, z.object({foo: z.string()}))",
      "llmArgs": { "foo": "x" }
    },
    "expected": {
      "executeArgs": { "foo": "x" }
    }
  },
  {
    "id": "TV-3",
    "requirementRef": "Tool.define guarantees execute receives parsed args",
    "scenarioRef": "validation error path preserved",
    "input": {
      "toolParameters_pseudocode": "z.object({foo: z.string()})",
      "llmArgs": { "baz": 1 }
    },
    "expected": {
      "executeInvoked": false,
      "throws": "ZodError (wrapped if formatValidationError present)"
    }
  },
  {
    "id": "TV-4",
    "requirementRef": "QuestionTool normalizes flat and string-option inputs",
    "scenarioRef": "flat single-question input wraps into questions array",
    "input": {
      "llmArgs": {
        "question": "single-surface shell 的 canonical authenticated route 要用哪個？",
        "options": [
          "`/assets` 作為唯一 canonical route",
          "`/inventory` 作為唯一 canonical route",
          "`/` 作為 shell route"
        ],
        "multiple": false
      }
    },
    "expected": {
      "executeArgs": {
        "questions": [
          {
            "question": "single-surface shell 的 canonical authenticated route 要用哪個？",
            "header": "single-surface shell 的 canonic",
            "options": [
              { "label": "`/assets` 作為唯一 canonical route", "description": "`/assets` 作為唯一 canonical route" },
              { "label": "`/inventory` 作為唯一 canonical route", "description": "`/inventory` 作為唯一 canonical route" },
              { "label": "`/` 作為 shell route", "description": "`/` 作為 shell route" }
            ],
            "multiple": false
          }
        ]
      },
      "questionAskCalledWith_questions_length": 1,
      "doesNotThrow": "TypeError: undefined is not an object (evaluating 'input.questions.length')"
    }
  },
  {
    "id": "TV-5",
    "requirementRef": "QuestionTool normalizes flat and string-option inputs",
    "scenarioRef": "string options coerced into {label, description}",
    "input": {
      "llmArgs": {
        "questions": [
          { "question": "X?", "options": ["A", "B"], "multiple": false }
        ]
      }
    },
    "expected": {
      "executeArgs": {
        "questions": [
          {
            "question": "X?",
            "header": "X?",
            "options": [
              { "label": "A", "description": "A" },
              { "label": "B", "description": "B" }
            ],
            "multiple": false
          }
        ]
      }
    }
  },
  {
    "id": "TV-6",
    "requirementRef": "QuestionTool normalizes flat and string-option inputs",
    "scenarioRef": "already-canonical input passes through unchanged",
    "input": {
      "llmArgs": {
        "questions": [
          {
            "question": "X?",
            "header": "X",
            "options": [{ "label": "A", "description": "desc" }],
            "multiple": false
          }
        ]
      }
    },
    "expected": {
      "executeArgs": {
        "questions": [
          {
            "question": "X?",
            "header": "X",
            "options": [{ "label": "A", "description": "desc" }],
            "multiple": false
          }
        ]
      }
    }
  },
  {
    "id": "TV-7",
    "requirementRef": "QuestionTool normalizes flat and string-option inputs",
    "scenarioRef": "multi-question with multiple=true",
    "input": {
      "llmArgs": {
        "questions": [
          { "question": "Q1?", "options": ["A", "B", "C"], "multiple": true },
          { "question": "Q2?", "options": ["X", "Y"], "multiple": false }
        ]
      }
    },
    "expected": {
      "executeArgs_questions_length": 2,
      "executeArgs_questions_0_multiple": true,
      "executeArgs_questions_0_options_0": { "label": "A", "description": "A" },
      "executeArgs_questions_1_multiple": false,
      "executeArgs_questions_1_header_startsWith": "Q2?"
    }
  },
  {
    "id": "TV-8",
    "requirementRef": "state.input persisted as normalized shape for successful calls",
    "scenarioRef": "successful tool call persists normalized input",
    "input": {
      "processorStream": [
        { "type": "tool-call", "toolName": "question", "toolCallId": "c1", "input": { "question": "X?", "options": ["A"], "multiple": false } },
        { "type": "tool-result", "toolCallId": "c1", "input": { "question": "X?", "options": ["A"], "multiple": false }, "output": { "title": "Asked 1 question", "output": "...", "metadata": { "answers": [["A"]] } } }
      ]
    },
    "expected": {
      "toolPart_state_input": {
        "questions": [
          {
            "question": "X?",
            "header": "X?",
            "options": [{ "label": "A", "description": "A" }],
            "multiple": false
          }
        ]
      },
      "toolPart_state_status": "completed"
    }
  },
  {
    "id": "TV-9",
    "requirementRef": "state.input persisted as normalized shape for successful calls",
    "scenarioRef": "failed tool call preserves raw input",
    "input": {
      "processorStream": [
        { "type": "tool-call", "toolName": "question", "toolCallId": "c2", "input": { "baz": 1 } },
        { "type": "tool-error", "toolCallId": "c2", "input": { "baz": 1 }, "error": "ZodError ..." }
      ]
    },
    "expected": {
      "toolPart_state_input": { "baz": 1 },
      "toolPart_state_status": "error"
    }
  },
  {
    "id": "TV-10",
    "requirementRef": "state.input persisted as normalized shape for successful calls",
    "scenarioRef": "other tools unaffected",
    "input": {
      "processorStream": [
        { "type": "tool-call", "toolName": "bash", "toolCallId": "c3", "input": { "command": "ls" } },
        { "type": "tool-result", "toolCallId": "c3", "input": { "command": "ls" }, "output": { "title": "bash", "output": "a b c", "metadata": {} } }
      ]
    },
    "expected": {
      "toolPart_state_input_structurallyEqual_raw": true
    }
  },
  {
    "id": "TV-11",
    "requirementRef": "UI renderers defensively normalize legacy raw shape",
    "scenarioRef": "QuestionDock renders raw-shape message from legacy session",
    "input": {
      "state_input_raw": {
        "questions": [
          { "question": "single-surface shell 的 canonical authenticated route 要用哪個？", "options": ["/assets", "/inventory", "/"], "multiple": false }
        ]
      }
    },
    "expected": {
      "rendered_tab_header": "single-surface shell 的 canonic",
