{
  "diagram_title": "Session Poll Defence Layer",
  "node_reference": "A0",
  "activities": [
    {
      "id": "A1",
      "title": "Serve Cached Session Read",
      "description": "Return session metadata and message list from in-process cache when fresh; on miss, load from storage and memoize.",
      "decomposition": null
    },
    {
      "id": "A2",
      "title": "Invalidate Cache On Write Event",
      "description": "Subscribe to MessageV2.Event.* and Session.Event.* (including worker-bridged events) and drop all cache keys for the affected sessionID; bump per-session version counter.",
      "decomposition": null
    },
    {
      "id": "A3",
      "title": "Evaluate Conditional GET",
      "description": "Compute weak ETag from sessionID + version; compare If-None-Match header; short-circuit with 304 when matching.",
      "decomposition": null
    },
    {
      "id": "A4",
      "title": "Enforce Per-Identity Rate Limit",
      "description": "Apply token-bucket per (username, method, routePattern); return 429 with Retry-After when exhausted; exempt internal and health paths.",
      "decomposition": null
    },
    {
      "id": "A5",
      "title": "Expose Cache And RateLimit Health",
      "description": "Serve GET /api/v2/server/cache/health with entries, hit/miss rate, eviction count, subscriptionAlive, and rate-limit stats over the past 5 minutes.",
      "decomposition": null
    },
    {
      "id": "A6",
      "title": "Load Tunables From tweaks.cfg",
      "description": "Parse /etc/opencode/tweaks.cfg with defaults; log actual effective values at startup; warn (not silently fall back) on format errors.",
      "decomposition": null
    }
  ],
