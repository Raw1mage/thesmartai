[
  {
    "diagram_title": "Daemon startup — first session use bumps epoch to 1",
    "scenario": "Fresh daemon, first message arrives on a session; lazy-bump from 0 to 1 triggers full capability layer reinject",
    "moduleRef": "A1",
    "participants": [
      { "id": "P1", "name": "User", "type": "actor", "componentRef": "C8" },
      { "id": "P2", "name": "SessionPrompt.runLoop", "type": "component", "componentRef": "C8" },
      { "id": "P3", "name": "RebindEpoch", "type": "component", "componentRef": "C1" },
      { "id": "P4", "name": "CapabilityLayer", "type": "component", "componentRef": "C4" },
      { "id": "P5", "name": "RuntimeEventService", "type": "component", "componentRef": "C14" }
    ],
    "messages": [
      { "id": "MSG1", "from": "P1", "to": "P2", "label": "send message to session S", "type": "sync", "order": 1 },
      { "id": "MSG2", "from": "P2", "to": "P3", "label": "current(S) → 0 (uninitialized)", "type": "sync", "order": 2 },
      { "id": "MSG3", "from": "P2", "to": "P3", "label": "bumpEpoch(S, trigger=daemon_start)", "type": "sync", "order": 3 },
      { "id": "MSG4", "from": "P3", "to": "P3", "label": "epoch 0 → 1, clear cache for S", "type": "sync", "order": 4 },
      { "id": "MSG5", "from": "P3", "to": "P5", "label": "append session.rebind {trigger: daemon_start, 0→1}", "type": "async", "order": 5 },
      { "id": "MSG6", "from": "P2", "to": "P4", "label": "get(S, epoch=1) → cache miss", "type": "sync", "order": 6 },
      { "id": "MSG7", "from": "P4", "to": "P4", "label": "reinject: read AGENTS.md + driver + skills + enablement", "type": "sync", "order": 7 },
      { "id": "MSG8", "from": "P4", "to": "P5", "label": "append capability_layer.refreshed {epoch: 1, layers, pinnedSkills}", "type": "async", "order": 8 },
      { "id": "MSG9", "from": "P4", "to": "P2", "label": "return layer strings", "type": "return", "order": 9 },
      { "id": "MSG10", "from": "P2", "to": "P1", "label": "LLM response delivered", "type": "return", "order": 10 }
    ],
    "fragments": []
  },
  {
