  {
    "diagram_title": "Provider switch — capability layer refresh BEFORE checkpoint apply",
    "scenario": "User switches model/account from anthropic to codex; pre-loop detection bumps epoch, refreshes capability layer, then compacts messages with new provider; order contract ensures new LLM sees fresh capability layer",
    "moduleRef": "A3",
    "participants": [
      { "id": "P1", "name": "User action", "type": "actor", "componentRef": "C8" },
      { "id": "P2", "name": "SessionPrompt.runLoop", "type": "component", "componentRef": "C8" },
      { "id": "P3", "name": "Provider-switch detection", "type": "component", "componentRef": "C9" },
      { "id": "P4", "name": "RebindEpoch", "type": "component", "componentRef": "C1" },
      { "id": "P5", "name": "CapabilityLayer", "type": "component", "componentRef": "C4" },
      { "id": "P6", "name": "SessionCompaction (checkpoint)", "type": "component", "componentRef": "C8" }
    ],
    "messages": [
      { "id": "MSG1", "from": "P1", "to": "P2", "label": "incomingModel = codex (prev: anthropic)", "type": "sync", "order": 1 },
      { "id": "MSG2", "from": "P2", "to": "P3", "label": "detect: prevProvider !== nextProvider", "type": "sync", "order": 2 },
      { "id": "MSG3", "from": "P3", "to": "P4", "label": "bumpEpoch(S, trigger=provider_switch)", "type": "sync", "order": 3 },
      { "id": "MSG4", "from": "P4", "to": "P4", "label": "clear cache, epoch++", "type": "sync", "order": 4 },
      { "id": "MSG5", "from": "P3", "to": "P5", "label": "reinject(S)", "type": "sync", "order": 5 },
      { "id": "MSG6", "from": "P5", "to": "P5", "label": "read fresh AGENTS.md + codex driver prompt + skills", "type": "sync", "order": 6 },
      { "id": "MSG7", "from": "P3", "to": "P6", "label": "compactWithSharedContext(sessionID, model=codex)", "type": "sync", "order": 7 },
      { "id": "MSG8", "from": "P6", "to": "P3", "label": "messages compacted", "type": "return", "order": 8 },
      { "id": "MSG9", "from": "P3", "to": "P2", "label": "continue runLoop", "type": "return", "order": 9 },
      { "id": "MSG10", "from": "P2", "to": "P2", "label": "build system[] with fresh capability layer + compacted msgs", "type": "sync", "order": 10 }
    ],
    "fragments": [
      { "id": "FRAG1", "type": "par", "label": "Order guarantee: MSG5-6 MUST finish before MSG7", "messageRefs": ["MSG5", "MSG6", "MSG7"] }
    ]
  },
