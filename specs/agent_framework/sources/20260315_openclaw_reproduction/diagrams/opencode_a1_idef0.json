      "title": "Scope Session Key Namespace",
      "description": "Assign cron:<jobId>:run:<uuid> key for isolated sessions vs agent:<agentId>:main for main sessions. Enforce uniqueness and ancestry tracking.",
      "decomposition": null
    },
    {
      "id": "A12",
      "title": "Bootstrap Lightweight Context",
      "description": "Skip workspace file injection when lightContext=true. Provide cron-prefixed system prompt with minimal token footprint.",
      "decomposition": null
    },
    {
      "id": "A13",
      "title": "Route Delivery Output",
      "description": "Choose announce/webhook/none for isolated job results. Post summary to main session if configured. Chunk per channel format rules.",
      "decomposition": null
    },
    {
      "id": "A14",
      "title": "Enforce Session Retention Policy",
      "description": "Prune expired cron run-sessions by age (default 24h). Trim run-log JSONL by size (2MB) and line count (2000). Remove orphaned storage entries.",
      "decomposition": null
    }
  ],
