  "diagram_title": "Schedule Trigger Evaluation — D.2 Decomposition",
  "node_reference": "A2",
  "activities": [
    {
      "id": "A21",
      "title": "Parse Schedule Expression",
      "description": "Handle at/every/cron schedule kinds. Apply IANA timezone conversion. Compute deterministic stagger offset for top-of-hour expressions to reduce thundering herd.",
      "decomposition": null
    },
    {
      "id": "A22",
      "title": "Gate Active Hours Window",
      "description": "Filter trigger firing against activeHours.start/end configuration. Suppress triggers outside the window. Compute next eligible fire time when suppressed.",
      "decomposition": null
    },
    {
      "id": "A23",
      "title": "Dispatch System Event",
      "description": "For main-session wakeup: enqueue SystemEvent into in-memory queue (max 20/session). Support wake modes: now (immediate heartbeat) vs next-heartbeat (batched).",
      "decomposition": null
    },
    {
      "id": "A24",
      "title": "Dispatch Agent Turn",
      "description": "For isolated jobs: create fresh session via A11, run agentTurn payload with optional model/thinking overrides. For main-session: inject into existing session context.",
      "decomposition": null
    }
  ],
