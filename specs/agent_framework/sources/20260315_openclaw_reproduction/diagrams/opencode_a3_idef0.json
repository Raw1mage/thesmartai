{
  "diagram_title": "Supervise Daemon Lifecycle — D.3 Decomposition",
  "node_reference": "A3",
  "activities": [
    {
      "id": "A31",
      "title": "Acquire Gateway Lock",
      "description": "Prevent multiple daemon instances via port-based or file-based lock. Release lock on shutdown. Reacquire on in-process restart.",
      "decomposition": null
    },
    {
      "id": "A32",
      "title": "Handle Signal Dispatch",
      "description": "SIGTERM/SIGINT trigger graceful shutdown path. SIGUSR1 triggers in-process restart with authorization check. Map signals to lifecycle transitions.",
      "decomposition": null
    },
    {
      "id": "A33",
      "title": "Execute Drain State Machine",
      "description": "Mark gateway as draining. Reject new task enqueues with GatewayDrainingError. Wait for active tasks to complete within DRAIN_TIMEOUT_MS (90s). Abort embedded agent runs.",
      "decomposition": null
    },
    {
      "id": "A34",
      "title": "Coordinate Process Restart",
      "description": "Try full process respawn via restartGatewayProcessWithFreshPid(). Fall back to in-process restart if OPENCLAW_NO_RESPAWN. Close HTTP server, inform clients with restartExpectedMs.",
      "decomposition": null
    },
    {
      "id": "A35",
      "title": "Track Lifecycle Generation Number",
      "description": "Increment generation counter on each restart cycle. Stale task completions from previous generations are ignored by lane pump. Enables safe in-process restart without data corruption.",
      "decomposition": null
    }
  ],
