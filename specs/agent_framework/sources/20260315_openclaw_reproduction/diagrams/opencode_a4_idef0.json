  "diagram_title": "Govern Command Lane Execution — D.3 Queue Decomposition",
  "node_reference": "A4",
  "activities": [
    {
      "id": "A41",
      "title": "Register Lane Concurrency",
      "description": "Define command lanes (Main/Cron/Subagent/Nested) with per-lane maxConcurrent limits. Support per-session lanes for single-threaded session execution.",
      "decomposition": null
    },
    {
      "id": "A42",
      "title": "Enqueue Task With Drain Guard",
      "description": "Accept task for lane execution. Reject with GatewayDrainingError if draining flag is set. Assign task ID and track enqueue timestamp. Emit diagnostic if queue wait exceeds threshold.",
      "decomposition": null
    },
    {
      "id": "A43",
      "title": "Pump Lane Priority Drain",
      "description": "Per-lane pump loop: dequeue next task when active count < maxConcurrent. Track activeTaskIds per generation. Execute task and resolve/reject promise on completion.",
      "decomposition": null
    },
    {
      "id": "A44",
      "title": "Reset Lane State Post Restart",
      "description": "Clear all activeTaskIds sets. Bump generation number to invalidate stale completions. Re-drain any queued entries that survived the restart cycle.",
      "decomposition": null
    }
  ],
