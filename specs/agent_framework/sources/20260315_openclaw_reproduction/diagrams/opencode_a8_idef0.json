{
  "diagram_title": "Govern Channel Extensions — Stage D Decomposition",
  "node_reference": "A8",
  "activities": [
    {
      "id": "A81",
      "title": "Enforce Channel Quota and Rate Limits",
      "description": "Define per-channel token budget, request rate ceiling, and concurrent session cap. Reject or queue requests exceeding limits.",
      "decomposition": "A81"
    },
    {
      "id": "A82",
      "title": "Scope Cron Jobs to Channel",
      "description": "Associate cron job definitions with a channel. Channel kill-switch suppresses channel-scoped cron triggers. Channel deletion cascades to cron job disable.",
      "decomposition": null
    },
    {
      "id": "A83",
      "title": "Execute Channel Migration",
      "description": "Move sessions and cron jobs between channels. Preserve session history and run-logs. Re-key lane namespace to target channel.",
      "decomposition": null
    },
    {
      "id": "A84",
      "title": "Enforce Channel Access Control",
      "description": "Define per-channel RBAC roles (owner, operator, viewer). Gate channel CRUD, session creation, and kill-switch trigger by role. Audit role-gated actions.",
      "decomposition": null
    }
  ],
