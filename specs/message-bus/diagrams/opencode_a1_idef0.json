      "title": "Parse Event Type And Props",
      "description": "Extract topic type and properties from Bus.publish(Topic, props) call. Support multi-topic publish for different granularity output.",
      "decomposition": null
    },
    {
      "id": "A12",
      "title": "Validate Against Zod Schema",
      "description": "Run zod parse on event props using schema from BusEvent.define(). Reject invalid payloads before dispatch.",
      "decomposition": null
    },
    {
      "id": "A13",
      "title": "Resolve Topic Subscriber List",
      "description": "Look up all registered callbacks for this topic in Bus.subscribe registry. Include wildcard subscribers (SSE transport).",
      "decomposition": null
    },
    {
      "id": "A14",
      "title": "Dispatch To Each Subscriber",
      "description": "Synchronous push: forEach subscriber callback, invoke with validated props. Fire-and-forget — no queue, no buffer.",
      "decomposition": null
    }
