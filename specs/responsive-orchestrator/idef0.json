{
  "diagram_title": "Responsive Orchestrator — Async Task Tool with Disk-Terminal Delivery",
  "node_reference": "A0",
  "activities": [
    {
      "id": "A1",
      "title": "Dispatch task & return stub immediately",
      "description": "Main agent emits task tool call. Tool spawns subagent worker, allocates jobId + childSessionID, returns dispatched stub result satisfying LLM tool-use protocol (DD-1).",
      "decomposition": null
    },
    {
      "id": "A2",
      "title": "Run subagent independently",
      "description": "Subagent worker process executes its runloop in isolation. Includes the new post-turn quota check (R6) and reactive 429 handling with bounded escalation wait (R3).",
      "decomposition": null
    },
    {
      "id": "A3",
      "title": "Detect terminal finish & emit completed event",
      "description": "Background watcher (formerly the synchronous await) monitors child via watchdog A/B/C. On any TERMINAL_FINISHES disk write or proc death, emits TaskCompletedEvent on Bus.",
      "decomposition": null
    },
    {
      "id": "A4",
      "title": "Inject synthetic task_result message into parent",
      "description": "Subscriber consumes TaskCompletedEvent, builds TaskResultMessage payload, appends as MessageV2.User with synthetic.source='task_result' to parent session. Triggers parent runloop wakeup.",
      "decomposition": null
    },
    {
      "id": "A5",
      "title": "Cancel running subagent (out-of-band)",
      "description": "Main agent invokes cancel_task tool. Single authority pattern (DD-6): signal abort, worker writes 'cancelled' finish, normal A3+A4 path delivers result. cancel_task returns within 1s.",
      "decomposition": null
    }
  ],
