{
  "diagram_title": "session-rebind-capability-refresh — Rebind Event → Capability Layer Refresh Pipeline",
  "node_reference": "A0",
  "activities": [
    {
      "id": "A1",
      "title": "Manage Rebind Epoch",
      "description": "維護 per-session 整數 epoch counter；提供 bumpEpoch API；強制 rate limit（5/sec/session）；bump 時清除同 session 能力層 cache 並發 session.rebind 事件。",
      "decomposition": null
    },
    {
      "id": "A2",
      "title": "Refresh Capability Layer",
      "description": "讀磁碟上的 AGENTS.md（global + project）、driver prompt、mandatory skills 內容、enablement.json；填入 (sessionID, epoch)-keyed cache；發 capability_layer.refreshed 事件；失敗時保留前一個 epoch 的 cache 不覆寫。",
      "decomposition": null
    },
    {
      "id": "A3",
      "title": "Assemble Session Prompt",
      "description": "runLoop 每輪呼叫：取當前 epoch → 從 cache 取能力層（cache miss 觸發 A2 reinject）→ 套 rebind checkpoint / SharedContext 對話層壓縮 → 組 system[] → 送 LLM。契約：能力層取得順序**必須**早於 checkpoint apply。",
      "decomposition": null
    },
    {
      "id": "A4",
      "title": "Accept Explicit Refresh Trigger",
      "description": "暴露兩個 rebind 入口：`/reload` slash command（使用者手動）、`refresh_capability_layer` tool call（AI 主動，per-turn 3 次 rate limit）。兩者共用 A1 的 bumpEpoch API。",
      "decomposition": null
    },
    {
      "id": "A5",
      "title": "Accept UI Session Resume Signal",
      "description": "新 HTTP endpoint `POST /session/:id/resume`；驗證來源（同 uid Unix socket origin）；呼叫 A1 bumpEpoch + A2 reinject，整個過程不打 LLM（silent init round）；發 SSE event 給 UI 重繪 dashboard。",
      "decomposition": null
    },
    {
      "id": "A6",
      "title": "Record Observability Events",
      "description": "所有 rebind 事件透過 RuntimeEventService 發佈：session.rebind（成功 bump）、capability_layer.refreshed（reinject 完成）、session.rebind_storm（rate limit 超過）、capability_layer.refresh_failed（reinject 例外）、tool.refresh_loop_suspected（per-turn 超限）。",
      "decomposition": null
    }
  ],
