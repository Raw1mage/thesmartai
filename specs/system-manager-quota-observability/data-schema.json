{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "system-manager-quota-observability data contracts",
  "$defs": {
    "UsagePayload": {
      "type": "object",
      "required": ["fiveHourPercent", "weeklyPercent", "nextResetAt"],
      "properties": {
        "fiveHourPercent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Percentage of the 5-hour window consumed. 0 = fresh, 100 = exhausted."
        },
        "weeklyPercent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Percentage of the weekly window consumed."
        },
        "nextResetAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp of the next 5-hour window reset."
        }
      }
    },
    "CachedMeta": {
      "type": "object",
      "required": ["cachedAt", "ageSeconds"],
      "properties": {
        "cachedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When this usage snapshot was fetched from the live API."
        },
        "ageSeconds": {
          "type": "integer",
          "minimum": 0,
          "description": "Seconds elapsed since cachedAt. AI uses this to judge staleness."
        }
      }
    },
    "SupportedQuotaResponse": {
      "type": "object",
      "required": ["supported", "provider", "family", "accountId", "usage", "cachedAt", "ageSeconds"],
      "properties": {
        "supported": { "const": true },
        "provider": { "type": "string", "description": "canonical provider id, e.g. 'codex'" },
        "family": { "type": "string", "description": "family grouping, e.g. 'openai'" },
        "accountId": { "type": "string", "description": "The pinned execution.accountId for this session." },
        "usage": { "$ref": "#/$defs/UsagePayload" },
        "cachedAt": { "$ref": "#/$defs/CachedMeta/properties/cachedAt" },
        "ageSeconds": { "$ref": "#/$defs/CachedMeta/properties/ageSeconds" }
      },
      "additionalProperties": false
    },
    "UnsupportedQuotaResponse": {
      "type": "object",
      "required": ["supported", "reason"],
      "properties": {
        "supported": { "const": false },
        "provider": { "type": "string", "description": "canonical provider id if known" },
        "family": { "type": "string", "description": "family if known" },
        "reason": {
          "type": "string",
          "enum": [
            "provider does not expose usage endpoint",
            "no pinned execution identity for this session",
            "session not found",
            "bridge did not inject sessionID"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "definitions_top": {
    "get_my_current_usage": {
      "input": {
        "type": "object",
        "properties": {
          "sessionID": {
            "type": "string",
            "description": "Optional override. Normally auto-injected by opencode MCP bridge; LLM does not need to pass it."
          }
        },
        "additionalProperties": false
      },
      "output": {
        "oneOf": [
          { "$ref": "#/$defs/SupportedQuotaResponse" },
          { "$ref": "#/$defs/UnsupportedQuotaResponse" }
        ]
      }
    },
    "get_system_status_extension": {
      "input_additions": {
        "sessionID": {
          "type": "string",
          "description": "Optional. When provided, each family's response includes currentInflightAccount derived from that session's pinned execution identity."
        }
      },
      "output_per_family_additions": {
        "currentInflightAccount": {
          "type": ["string", "null"],
          "description": "Account ID rotation actually picked for the given session's in-flight requests. null when sessionID not provided or session has no pinned identity. Distinct from selectedAccount (UI-selected)."
        }
      },
      "output_per_account_usage_additions": {
        "cachedAt": { "$ref": "#/$defs/CachedMeta/properties/cachedAt" },
        "ageSeconds": { "$ref": "#/$defs/CachedMeta/properties/ageSeconds" }
      }
    },
    "quota_cache_file": {
      "description": "~/.config/opencode/quota-cache.json — keyed by '{providerCanonical}:{accountId}'",
      "type": "object",
      "patternProperties": {
        "^[a-z0-9-]+:.+$": {
          "type": "object",
          "required": ["fiveHourPercent", "weeklyPercent", "nextResetAt", "cachedAt"],
          "properties": {
            "fiveHourPercent": { "type": "number" },
            "weeklyPercent": { "type": "number" },
            "nextResetAt": { "type": "string", "format": "date-time" },
            "cachedAt": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    "AccountQuotaProbe_interface": {
      "description": "TypeScript interface (documented here for traceability).",
      "pseudo_ts": "interface AccountQuotaProbe { probe(accountId: string): Promise<UsagePayload | { supported: false; reason: string }> }"
    }
  }
}
