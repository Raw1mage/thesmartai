[
  {
    "id": "S0",
    "label": "Idle",
    "description": "Waiting for LLM tool call",
    "actions": [],
    "transitions": [
      { "to": "S1", "condition": "MCP bridge receives get_my_current_usage call", "refs": ["A1", "A2"] }
    ]
  },
  {
    "id": "S1",
    "label": "Bridge inject sessionID",
    "description": "opencode MCP bridge attempts to inject ctx.sessionID into args",
    "actions": ["dynamicTool wrapper augments args"],
    "transitions": [
      { "to": "S2", "condition": "ctx.sessionID present", "refs": ["A2"] },
      { "to": "S_UNSUP", "condition": "ctx.sessionID absent (R-1)", "refs": ["A2", "A6"] }
    ]
  },
  {
    "id": "S2",
    "label": "Read session info",
    "description": "MCP tool handler reads session info.json",
    "actions": ["fs.readFile(session/info.json)"],
    "transitions": [
      { "to": "S3", "condition": "execution.accountId non-null", "refs": ["A3"] },
      { "to": "S_UNSUP", "condition": "no pinned execution identity", "refs": ["A3", "A6"] }
    ]
  },
  {
    "id": "S3",
    "label": "Dispatch to provider probe",
    "description": "AccountQuotaProbe registry lookup by providerId",
    "actions": ["registry.get(providerId)"],
    "transitions": [
      { "to": "S4", "condition": "probe exists", "refs": ["A4"] },
      { "to": "S_UNSUP", "condition": "provider not registered / unsupported", "refs": ["A4", "A6"] }
    ]
  },
  {
    "id": "S4",
    "label": "Check cache",
    "description": "Read quota-cache.json[providerCanonical:accountId]",
    "actions": ["read quota-cache.json"],
    "transitions": [
      { "to": "S5", "condition": "cache miss OR ageSeconds > TTL", "refs": ["A5"] },
      { "to": "S6", "condition": "cache fresh (ageSeconds <= TTL)", "refs": ["A5"] }
    ]
  },
  {
    "id": "S5",
    "label": "Fetch live API",
    "description": "Hit CODEX_USAGE_URL, then write cache",
    "actions": ["fetch live API", "write quota-cache.json"],
    "transitions": [
      { "to": "S6", "condition": "fetch OK + cache written", "refs": ["A5", "A6"] }
    ]
  },
  {
    "id": "S6",
    "label": "Compose response",
    "description": "Serialize UsagePayload + cachedAt + ageSeconds",
    "actions": ["compute ageSeconds", "JSON serialize"],
    "transitions": [
      { "to": "S_DONE", "condition": "response serialized", "refs": ["A6"] }
    ]
  },
  {
    "id": "S_UNSUP",
    "label": "Unsupported path",
    "description": "Compose {supported:false, reason}; forbid silent fallback",
    "actions": ["compose unsupported response with explicit reason"],
    "transitions": [
      { "to": "S_DONE", "condition": "unsupported response composed", "refs": ["A6"] }
    ]
  },
  {
    "id": "S_DONE",
    "label": "Response returned",
    "description": "MCP tool response delivered to LLM",
    "actions": [],
    "transitions": [
      { "to": "S0", "condition": "next tool call", "refs": [] }
    ]
  }
]
