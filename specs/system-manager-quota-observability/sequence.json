[
  {
    "id": "P1",
    "title": "Subagent self-check on fresh cache",
    "actors": ["subagent-llm", "bridge", "tool", "session-info", "registry", "codex-probe", "cache"],
    "messages": [
      { "id": "MSG1", "from": "subagent-llm", "to": "bridge", "componentRef": "C1", "label": "callTool(get_my_current_usage, {})" },
      { "id": "MSG2", "from": "bridge", "to": "tool", "componentRef": "C5", "label": "callTool with injected {sessionID: 'ses_abc'}" },
      { "id": "MSG3", "from": "tool", "to": "session-info", "componentRef": "C8", "label": "readFile(ses_abc/info.json)" },
      { "id": "MSG4", "from": "session-info", "to": "tool", "componentRef": "C5", "label": "{execution: {providerId: 'codex', accountId: 'acc_42'}}" },
      { "id": "MSG5", "from": "tool", "to": "registry", "componentRef": "C3", "label": "probe('codex', 'acc_42')" },
      { "id": "MSG6", "from": "registry", "to": "codex-probe", "componentRef": "C4", "label": "probe('acc_42')" },
      { "id": "MSG7", "from": "codex-probe", "to": "cache", "componentRef": "C7", "label": "read['codex:acc_42']" },
      { "id": "MSG8", "from": "cache", "to": "codex-probe", "componentRef": "C4", "label": "{fiveHour: 42, weekly: 18, cachedAt, ageSeconds: 15}" },
      { "id": "MSG9", "from": "codex-probe", "to": "tool", "componentRef": "C5", "label": "UsagePayload (from cache)" },
      { "id": "MSG10", "from": "tool", "to": "subagent-llm", "componentRef": "C5", "label": "{supported:true, provider, family, accountId, usage, cachedAt, ageSeconds:15}" }
    ]
  },
  {
    "id": "P2",
    "title": "Cache stale → live refresh",
    "actors": ["llm", "tool", "codex-probe", "cache", "openai"],
    "messages": [
      { "id": "MSG1", "from": "llm", "to": "tool", "componentRef": "C5", "label": "callTool(get_my_current_usage)" },
      { "id": "MSG2", "from": "tool", "to": "codex-probe", "componentRef": "C4", "label": "probe(accountId)" },
      { "id": "MSG3", "from": "codex-probe", "to": "cache", "componentRef": "C7", "label": "read['codex:acc_42']" },
      { "id": "MSG4", "from": "cache", "to": "codex-probe", "componentRef": "C4", "label": "{ageSeconds: 120} > TTL 60" },
      { "id": "MSG5", "from": "codex-probe", "to": "openai", "componentRef": "C4", "label": "GET chatgpt.com/backend-api/wham/usage" },
      { "id": "MSG6", "from": "openai", "to": "codex-probe", "componentRef": "C4", "label": "{primary:{used_percent:67}, secondary:{used_percent:22}}" },
      { "id": "MSG7", "from": "codex-probe", "to": "cache", "componentRef": "C7", "label": "write['codex:acc_42'] = fresh payload" },
      { "id": "MSG8", "from": "codex-probe", "to": "tool", "componentRef": "C5", "label": "UsagePayload (fresh)" },
      { "id": "MSG9", "from": "tool", "to": "llm", "componentRef": "C5", "label": "{supported:true, usage, ageSeconds:0}" }
    ]
  },
  {
    "id": "P3",
    "title": "No pinned identity → unsupported",
    "actors": ["llm", "tool", "session-info"],
    "messages": [
      { "id": "MSG1", "from": "llm", "to": "tool", "componentRef": "C5", "label": "callTool(get_my_current_usage)" },
      { "id": "MSG2", "from": "tool", "to": "session-info", "componentRef": "C8", "label": "readFile(session info)" },
      { "id": "MSG3", "from": "session-info", "to": "tool", "componentRef": "C5", "label": "{execution: null}" },
      { "id": "MSG4", "from": "tool", "to": "llm", "componentRef": "C5", "label": "{supported:false, reason:'no pinned execution identity for this session'}" }
    ]
  },
  {
    "id": "P4",
    "title": "Main agent full-picture via extended get_system_status",
    "actors": ["main-llm", "tool", "session-info", "registry", "codex-probe"],
    "messages": [
      { "id": "MSG1", "from": "main-llm", "to": "tool", "componentRef": "C6", "label": "callTool(get_system_status, {sessionID: 'ses_abc'})" },
      { "id": "MSG2", "from": "tool", "to": "session-info", "componentRef": "C8", "label": "readFile(ses_abc/info.json).execution.accountId" },
      { "id": "MSG3", "from": "session-info", "to": "tool", "componentRef": "C6", "label": "'acc_42'" },
      { "id": "MSG4", "from": "tool", "to": "registry", "componentRef": "C3", "label": "probe each account per family (with cache)" },
      { "id": "MSG5", "from": "registry", "to": "tool", "componentRef": "C6", "label": "UsagePayload map per account" },
      { "id": "MSG6", "from": "tool", "to": "main-llm", "componentRef": "C6", "label": "{families: [{family:'openai', selectedAccount:'acc_7', currentInflightAccount:'acc_42', accounts:[{usage:{..., cachedAt, ageSeconds}}]}]}" }
    ]
  }
]
