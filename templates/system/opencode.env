# OpenCode system service environment
# Optional: absolute path to bun used by systemd service
# OPENCODE_BUN_BIN=/usr/local/bin/bun

OPENCODE_PORT=1080
OPENCODE_HOSTNAME=0.0.0.0

# Enable Linux run-as-user bridge (PAM/multi-user)
OPENCODE_RUN_AS_USER_ENABLED=1
OPENCODE_RUN_AS_USER_WRAPPER=/usr/local/libexec/opencode-run-as-user

# Optional external URL for absolute links
# OPENCODE_PUBLIC_URL=https://your-domain.example

# Legacy user-worker route flags are deprecated and removed from runtime routing.
# Keep them unset in production.

# Phase 1/2 preview: gateway + per-user daemon routing (strict mode, no fallback)
# OPENCODE_PER_USER_DAEMON_EXPERIMENTAL=1
# OPENCODE_PER_USER_DAEMON_LAZY_START=1
# OPENCODE_PER_USER_DAEMON_SYSTEMD_UNIT=opencode-user-daemon@.service
# OPENCODE_PER_USER_DAEMON_SYSTEMCTL_BIN=/usr/bin/systemctl
# OPENCODE_PER_USER_DAEMON_START_COOLDOWN_MS=30000
# OPENCODE_PER_USER_DAEMON_REQUEST_TIMEOUT_MS=5000
# OPENCODE_PER_USER_DAEMON_PORT_BASE=41000
# OPENCODE_PER_USER_DAEMON_PORT_SPAN=20000
# OPENCODE_PER_USER_DAEMON_ROUTE_CONFIG=1
# OPENCODE_PER_USER_DAEMON_ROUTE_ACCOUNT_LIST=1
# OPENCODE_PER_USER_DAEMON_ROUTE_ACCOUNT_MUTATION=1
# OPENCODE_PER_USER_DAEMON_ROUTE_SESSION_LIST=1
# OPENCODE_PER_USER_DAEMON_ROUTE_SESSION_STATUS=1
# OPENCODE_PER_USER_DAEMON_ROUTE_SESSION_TOP=1
# OPENCODE_PER_USER_DAEMON_ROUTE_SESSION_READ=1
# OPENCODE_PER_USER_DAEMON_ROUTE_SESSION_MUTATION=1
# OPENCODE_PER_USER_DAEMON_ROUTE_MODEL_PREFERENCES=1
